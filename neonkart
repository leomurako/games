        // スタート前のカウントダウン音
        function playCountdownBeep(isGo) {
            if (!audioCtx) return;
            try {
                if (audioCtx.state === 'suspended') audioCtx.resume();
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                
                osc.type = 'sine';
                if (isGo) {
                    osc.frequency.setValueAtTime(987.77, audioCtx.currentTime); 
                    gain.gain.setValueAtTime(0.12, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.6);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.6);
                } else {
                    osc.frequency.setValueAtTime(493.88, audioCtx.currentTime); 
                    gain.gain.setValueAtTime(0.10, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.35);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.35);
                }
            } catch(e) {}
        }

        function updateEngineSound(speed) {
            if (!audioCtx || !engineOsc || !engineFilter) return;
            try {
                const speedRatio = Math.max(0, Math.min(1.5, speed * 2.5));
                const targetFreq = 40 + speedRatio * 180;
                const targetFilter = 140 + speedRatio * 400;
                engineOsc.frequency.setTargetAtTime(targetFreq, audioCtx.currentTime, 0.1);
                engineFilter.frequency.setTargetAtTime(targetFilter, audioCtx.currentTime, 0.1);
            } catch(e) {}
        }

