                setTimeout(() => { filter.style.background = 'none'; }, 200);
            }
            if (camera) {
                camera.fov = 65;
                camera.updateProjectionMatrix();
            }
        }

        function updateRacePhysics() {
            if (!raceCurve || !gameActive || racers.length === 0 || !racers[0]) return;

            const trackLength = raceCurve.getLength();

            if (raceIntroState === 'countdown') {
                countdownTimer--;

                const isPressingAccel = keys['w'] || keys['arrowup'];
                if (isPressingAccel) {
                    if (accelPressedTime === -1) {
                        accelPressedTime = countdownTimer; 
                        if (countdownTimer > 120) {
                            rocketStartFailed = true;
                        }
                    }

                    const player = racers[0];
                    const tangent = raceCurve.getTangentAt(player.progress).normalize();
                    const smokePos = player.mesh.position.clone().sub(tangent.clone().multiplyScalar(0.8));
                    smokePos.y += 0.1;
                    spawnExhaustSmoke(smokePos);
                }

                const overlay = document.getElementById('countdown-overlay');
                if (overlay) {
                    if (countdownTimer > 120) {
                        overlay.innerText = "3";
                        overlay.style.color = "#ff4757";
                        if (countdownTimer === 179) playCountdownBeep(false);
                    } else if (countdownTimer > 60) {
                        overlay.innerText = "2";
                        overlay.style.color = "#ffa502";
                        if (countdownTimer === 119) playCountdownBeep(false);
                    } else if (countdownTimer > 0) {
                        overlay.innerText = "1";
                        overlay.style.color = "#2ed573";
                        if (countdownTimer === 59) playCountdownBeep(false);
                    } else if (countdownTimer === 0) {
                        overlay.innerText = "GO!";
                        overlay.style.color = "#1e90ff";
                        playCountdownBeep(true);

                        if (rocketStartFailed) {
                            racers[0].spinTimer = 90; 
                            playSound('hit');
                        } else if (accelPressedTime > 0 && accelPressedTime <= 120) {
                            const holdRatio = accelPressedTime / 120.0;
                            const boostDuration = Math.floor(holdRatio * 180); 
                            
                            racers[0].boostTimer = boostDuration;
                            triggerRocketStartBurst(racers[0].mesh.position);
                            playSound('boost');
                        }
                        
                        raceIntroState = 'racing';
                        setTimeout(() => { overlay.innerText = ""; }, 1000);
                    }
                }

                racers.forEach(racer => {
                    applySplinePlacement(racer);
                });
                updateExhaustSmoke();
                return;
            }

            racers.forEach((racer, index) => {
                if (racer.starTimer > 0) {
                    const h = (Date.now() % 500) / 500;
                    racer.mesh.children[0].material.color.setHSL(h, 1.0, 0.5); 
                } else if (racer.isPlayer) {
                    racer.mesh.children[0].material.color.set(gameState.kartColor); 
                }

                if (racer.spinTimer > 0) {
                    racer.spinTimer--;
                    racer.speed *= 0.85; 
                    racer.mesh.rotation.y += 0.45; 
                    if (racer.spinTimer === 0) racer.mesh.rotation.y = 0;
                    applySplinePlacement(racer);
                    return;
                }

                let targetSpeed = 0.0;
                let accel = 0.0032; 
                let decel = 0.0055; 

                const hasStar = racer.starTimer > 0;
                const hasBoost = racer.boostTimer > 0;

                if (racer.starTimer > 0) racer.starTimer--;
                if (racer.boostTimer > 0) racer.boostTimer--;

                if (racer.goldenTimer > 0) {
                    racer.goldenTimer--;
                    if (racer.goldenTimer === 0) {
                        racer.hasItem = null;
                        if (racer.isPlayer) {
                            gameState.hasItem = null;
                            document.getElementById('hud-item-ui').innerText = "";
                        }
                    }
                }

                let maxSpeedBase = racer.isPlayer ? 0.35 : 0.31;
                if (hasBoost) maxSpeedBase = 0.58; 
                if (hasStar) maxSpeedBase = 0.52;

                if (racer.lightningTimer > 0) {
                    racer.lightningTimer--;
                    racer.mesh.scale.set(0.48, 0.48, 0.48); 
                    maxSpeedBase *= 0.55; 
                    if (racer.lightningTimer === 0) {
                        racer.mesh.scale.set(1.0, 1.0, 1.0); 
                    }
                } else {
                    racer.mesh.scale.set(1.0, 1.0, 1.0);
                }

                if (racer.isPlayer) {
                    const isAccelerating = keys['w'] || keys['arrowup'];
                    if (isAccelerating) {
                        targetSpeed = maxSpeedBase;

                        const tangent = raceCurve.getTangentAt(racer.progress).normalize();
                        const smokePos = racer.mesh.position.clone().sub(tangent.clone().multiplyScalar(0.8));
                        smokePos.y += 0.1;
                        spawnExhaustSmoke(smokePos);
                    } else if (keys['s'] || keys['arrowdown']) {
                        targetSpeed = -0.15; 
                    }

                    if (hasBoost && Math.random() < 0.4) {
                        const tangent = raceCurve.getTangentAt(racer.progress).normalize();
                        const smokePos = racer.mesh.position.clone().sub(tangent.clone().multiplyScalar(0.8));
                        smokePos.y += 0.1;
                        spawnExhaustSmoke(smokePos);
                    }

                    let steeringInput = 0;
                    if (keys['a'] || keys['arrowleft']) steeringInput = -1; 
                    if (keys['d'] || keys['arrowright']) steeringInput = 1;  

                    if (leftWheelPivot && rightWheelPivot) {
                        let targetWheelYaw = 0;
                        if (steeringInput > 0) targetWheelYaw = -0.45;      
                        else if (steeringInput < 0) targetWheelYaw = 0.45;  
                        leftWheelPivot.rotation.y = THREE.MathUtils.lerp(leftWheelPivot.rotation.y, targetWheelYaw, 0.15);
                        rightWheelPivot.rotation.y = THREE.MathUtils.lerp(rightWheelPivot.rotation.y, targetWheelYaw, 0.15);
                    }

                    if (steeringInput !== 0) {
                        if (keys[' '] && racer.height === 0 && Math.abs(racer.speed) > 0.1) {
                            if (racer.driftState === 'none') {
                                racer.driftState = steeringInput > 0 ? 'right' : 'left';
                                racer.driftTimer = 0;
                                racer.heightVelocity = 3.2; 
                                racer.height = 0.05; 
                            }
                        }
                    }

                    if (racer.driftState !== 'none') {
                        if (racer.steerValue === undefined) racer.steerValue = 0;
                        racer.steerValue = THREE.MathUtils.lerp(racer.steerValue, steeringInput, 0.04);

                        let driftSpeedFactor = Math.max(0, Math.min(1.5, Math.abs(racer.speed) / 0.35));

                        if (racer.driftState === 'left') {
                            let slidePower = 0.14;
                            if (steeringInput < 0) { 
                                slidePower -= 0.09;
                            } else if (steeringInput > 0) { 
                                slidePower += 0.08;
                            }
                            racer.lateralOffset += slidePower * driftSpeedFactor;
                            racer.driftAngle = 0.28; 
                        } else if (racer.driftState === 'right') {
                            let slidePower = 0.14;
                            if (steeringInput > 0) { 
                                slidePower -= 0.09;
                            } else if (steeringInput < 0) { 
                                slidePower += 0.08;
                            }
                            racer.lateralOffset -= slidePower * driftSpeedFactor;
                            racer.driftAngle = -0.28; 
                        }

                        if (!keys[' ']) {
                            resolveMiniTurbo(racer);
                        }
                    } else {
                        let steerSpeedFactor = racer.speed * 2.85; 

                        if (steeringInput !== 0) {
                            if (racer.steerValue === undefined) racer.steerValue = 0;
                            racer.steerValue = THREE.MathUtils.lerp(racer.steerValue, steeringInput, 0.09);
                            racer.lateralOffset += racer.steerValue * 0.18 * steerSpeedFactor; 
                            racer.driftAngle = -steeringInput * 0.15; 
                        } else {
                            if (racer.steerValue === undefined) racer.steerValue = 0;
                            racer.steerValue = THREE.MathUtils.lerp(racer.steerValue, 0, 0.1);
                            racer.lateralOffset += racer.steerValue * 0.18 * steerSpeedFactor;
                            racer.driftAngle *= 0.8;
                        }
                    }

                    if (racer.driftState !== 'none' && racer.height === 0) {
                        racer.driftTimer++;

                        let sparkColor = null;
                        if (racer.driftTimer >= 145) {
                            sparkColor = 0xa55eea; 
                        } else if (racer.driftTimer >= 85) {
                            sparkColor = 0xff4757; 
                        } else if (racer.driftTimer >= 35) {
                            sparkColor = 0x00f0ff; 
                        }

                        if (sparkColor) {
                            const offsetSign = racer.driftState === 'left' ? 1 : -1;
                            const sparkPos = racer.mesh.position.clone()
                                .add(new THREE.Vector3(offsetSign * 0.5, 0, -0.4));
                            spawnDriftSpark(sparkPos, sparkColor);
                        }
                    }

                } else {
                    const player = racers[0];
                    let aiBaseMaxSpeed = maxSpeedBase * (0.94 + Math.sin(Date.now() * 0.0015 + index) * 0.08);
                    
                    if (player) {
                        const progressDiff = player.progress - racer.progress;
                        if (progressDiff > 0.12) {
                            aiBaseMaxSpeed *= 1.15; 
                        } else if (progressDiff < -0.15) {
                            aiBaseMaxSpeed *= 0.90; 
                        }
                    }

                    targetSpeed = aiBaseMaxSpeed;
                    
                    racer.aiThinkTimer--;
                    if (racer.aiThinkTimer <= 0) {
                        racer.aiThinkTimer = 25 + Math.random() * 30; 

                        if (racer.hasItem && !racer.isItemRoulette) {
                            if (racer.hasItem === "MUSHROOM" || racer.hasItem === "STAR" || racer.hasItem.startsWith("TRIPLE_MUSHROOM") || racer.hasItem === "GOLDEN_MUSHROOM") {
                                executeItemUse(racer, racer.hasItem);
                            } else if (racer.hasItem === "BANANA" || racer.hasItem === "TRIPLE_BANANA") {
                                const anyoneBehind = racers.some(other => other !== racer && (racer.progress - other.progress) > 0 && (racer.progress - other.progress) < 0.06);
                                if (anyoneBehind) executeItemUse(racer, racer.hasItem);
                            } else {
                                const anyoneAhead = racers.some(other => other !== racer && (other.progress - racer.progress) > 0 && (other.progress - racer.progress) < 0.15);
                                if (anyoneAhead) executeItemUse(racer, racer.hasItem);
                            }
                        }
                    }

                    const avoidOffset = getAIOvertakeOffset(racer, trackLength);
                    const baseLine = Math.sin(racer.progress * 12 + index) * 4.5; 
                    const finalTargetLine = baseLine + avoidOffset;
                    racer.lateralOffset += (finalTargetLine - racer.lateralOffset) * 0.06; 
                }

                if (racer.speed < targetSpeed) {
                    racer.speed += accel;
                    if (racer.speed > targetSpeed) racer.speed = targetSpeed;
                } else {
                    racer.speed -= decel;
                    if (racer.speed < targetSpeed) racer.speed = targetSpeed;
                }

                if (Math.abs(racer.lateralOffset) > ROAD_WIDTH / 2) {
                    racer.speed *= 0.92; 
                    racer.lateralOffset = Math.max(-ROAD_WIDTH/2 - 0.5, Math.min(ROAD_WIDTH/2 + 0.5, racer.lateralOffset));
                }

                racer.lastProgress = racer.progress;
                racer.progress += racer.speed / trackLength;

                if (racer.progress >= 1.0) {
                    racer.progress -= 1.0;
                    racer.lap++;
                } else if (racer.progress < 0.0) {
                    racer.progress += 1.0;
                    racer.lap--; 
                }

                if (racer.height > 0 || racer.heightVelocity !== 0) {
                    racer.heightVelocity -= 0.3; 
                    racer.height += racer.heightVelocity * 0.05;

                    if (racer.height <= 0) {
                        racer.height = 0;
                        racer.heightVelocity = 0;
                        if (racer.trickTimer > 0) {
                            racer.boostTimer = 85; 
                            racer.trickTimer = 0;
                            if (racer.isPlayer) { 
                                playSound('boost');
                                document.getElementById('screen-filter').style.background = 'rgba(255, 165, 2, 0.12)';
                                setTimeout(() => { document.getElementById('screen-filter').style.background = 'none'; }, 300);
                            }
                        }
                        racer.canTrick = false;
                    }
                }

                if (racer.trickTimer > 0) racer.trickTimer--;

                applySplinePlacement(racer);
            });

            updateEngineSound(racers[0].speed);

            // 車体衝突物理
            for (let i = 0; i < racers.length; i++) {
                for (let j = i + 1; j < racers.length; j++) {
                    const r1 = racers[i];
                    const r2 = racers[j];
                    
                    let dp = r1.progress - r2.progress;
                    if (dp > 0.5) dp -= 1.0;
                    if (dp < -0.5) dp += 1.0;
                    const ds = dp * trackLength; 
                    
                    if (Math.abs(ds) < 2.0) {
                        const dl = r1.lateralOffset - r2.lateralOffset;
                        const targetLateralDist = 1.4; 
                        
                        if (Math.abs(dl) < targetLateralDist) {
                            const sign = dl >= 0 ? 1.0 : -1.0;
                            const overlap = targetLateralDist - Math.abs(dl);
                            
                            r1.lateralOffset += overlap * 0.52 * sign;
                            r2.lateralOffset -= overlap * 0.52 * sign;
                            
                            r1.speed *= 0.98;
                            r2.speed *= 0.98;
                            
                            if (Math.random() < 0.1) {
                                const midPos = r1.mesh.position.clone().lerp(r2.mesh.position, 0.5);
                                spawnDriftSpark(midPos, 0xffcc00);
                            }
                        }
                    }
                }
            }

            updateCollectiblesAndProjectiles();
            updateDriftSparks();
            updateExhaustSmoke(); 
        }

        // 3段階ミニターボの解放
        function resolveMiniTurbo(racer) {
            if (racer.driftTimer > 145) { 
                racer.boostTimer = 180; 
                if (racer.isPlayer) { 
                    playSound('boost');
                    triggerBoostVisualEffect();
                }
            } else if (racer.driftTimer > 85) { 
                racer.boostTimer = 110; 
                if (racer.isPlayer) {
                    playSound('boost');
                    triggerBoostVisualEffect();
                }
            } else if (racer.driftTimer > 35) { 
                racer.boostTimer = 50;  
                if (racer.isPlayer) {
                    playSound('boost');
                    triggerBoostVisualEffect();
                }
            }
            racer.driftState = 'none';
            racer.driftTimer = 0;
        }

        function updateCollectiblesAndProjectiles() {
            if (!raceCurve) return;

            const trackLength = raceCurve.getLength();

            // アイテムBOX
            raceItems.forEach(item => {
                if (item.active) {
                    if (item.mesh) {
                        item.mesh.rotation.y += 0.05; 
                    }
                    racers.forEach(racer => {
                        const dist = racer.mesh.position.distanceTo(item.pos);
                        if (dist < 1.8) {
                            item.active = false;
                            item.mesh.visible = false;
                            item.respawnTimer = 180; 
                            triggerItemRoulette(racer);
                        }
                    });
                } else {
                    item.respawnTimer--;
                    if (item.respawnTimer <= 0) {
                        item.active = true;
                        item.mesh.visible = true;
                    }
                }
            });

            // ジャンプ台
            raceRamps.forEach(ramp => {
                racers.forEach(racer => {
                    const dist = racer.mesh.position.distanceTo(ramp.pos);
                    if (dist < 2.5 && racer.height === 0) {
                        racer.heightVelocity = 7.5;
                        racer.height = 0.15;
                        racer.canTrick = true;
                    }
                });
            });

            // バナナ
            for (let idx = raceBananas.length - 1; idx >= 0; idx--) {
                const b = raceBananas[idx];
                b.age++;
                if (b.mesh) b.mesh.rotation.y += 0.02; 
                
                let triggered = false;
                for (let j = 0; j < racers.length; j++) {
                    const racer = racers[j];
                    if (racer.spinTimer === 0) {
                        const dist = racer.mesh.position.distanceTo(b.pos);
                        if (dist < 1.5) {
                            racer.spinTimer = 60; 
                            playSound('hit');
                            scene.remove(b.mesh);
                            raceBananas.splice(idx, 1);
                            triggered = true;
                            break;
                        }
                    }
                }

                if (!triggered && b.age >= b.maxAge) {
                    scene.remove(b.mesh);
                    raceBananas.splice(idx, 1);
                }
            }

            // 甲羅 (緑・赤・トゲゾー)
            for (let i = raceProjectiles.length - 1; i >= 0; i--) {
                const p = raceProjectiles[i];
                p.progress += p.speed / trackLength;

                const ratio = p.progress % 1.0;
                const pos = raceCurve.getPointAt(ratio);
                const tangent = raceCurve.getTangentAt(ratio).normalize();
                const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize();

                let exploded = false;

                if (p.type === "blue" && p.target) {
                    p.lateralOffset += (p.target.lateralOffset - p.lateralOffset) * 0.15;
                    
                    let pDiff = p.target.progress - p.progress;
                    if (pDiff < -0.5) pDiff += 1.0;
                    if (pDiff > 0.5) pDiff -= 1.0;
                    
                    const distToTarget = Math.abs(pDiff) * trackLength;
                    if (distToTarget < 3.0 && p.mesh.position.distanceTo(p.target.mesh.position) < 4.0) {
                        p.target.spinTimer = 120; 
                        triggerBlueShellExplosion(p.target.mesh.position);
                        playSound('hit');
                        exploded = true;
                    }
                } else {
                    if (p.type === "red" && p.target) {
                        p.lateralOffset += (p.target.lateralOffset - p.lateralOffset) * 0.16;
                    }

                    for (let j = 0; j < racers.length; j++) {
                        const racer = racers[j];
                        if (racer !== p.owner) {
                            const dist = p.mesh.position.distanceTo(racer.mesh.position);
                            if (dist < 1.8) {
                                racer.spinTimer = 80; 
                                playSound('hit');
                                exploded = true;
                                break;
                            }
                        }
                    }
                }

                const finalPos = pos.clone().add(normal.multiplyScalar(p.lateralOffset)).add(new THREE.Vector3(0, 0.4, 0));
                p.mesh.position.copy(finalPos);
                p.mesh.rotation.y += 0.05; 

                if (exploded || p.progress > 2.0) {
                    scene.remove(p.mesh);
                    raceProjectiles.splice(i, 1);
                }
            }
        }

        function applySplinePlacement(racer) {
            if (!raceCurve) return; 
            const ratio = (racer.progress + 1.0) % 1.0;
            const pos = raceCurve.getPointAt(ratio);
            const tangent = raceCurve.getTangentAt(ratio).normalize();
            
            const right = new THREE.Vector3().crossVectors(tangent, new THREE.Vector3(0, 1, 0)).normalize();

            const finalPos = pos.clone()
                .add(right.clone().multiplyScalar(racer.lateralOffset))
                .add(new THREE.Vector3(0, racer.height + 0.15, 0));

            racer.mesh.position.copy(finalPos);

            if (racer.spinTimer === 0) {
                const flatTangent = new THREE.Vector3(tangent.x, 0, tangent.z).normalize();
                const flatTarget = finalPos.clone().add(flatTangent);
                
                racer.mesh.lookAt(flatTarget);

                if (racer.trickTimer > 0) {
                    racer.mesh.rotation.x += 0.25; 
                } else if (racer.isPlayer) {
                    racer.mesh.rotation.y += racer.driftAngle;
                }
            }
        }

        // ========================================================
        // 11. カメラワーク更新
        // ========================================================
        function updateCamera() {
            if (racers.length === 0 || !racers[0]) return; 
            const player = racers[0];
            if (!player || !camera || !raceCurve || !gameActive) return;

            camera.fov = THREE.MathUtils.lerp(camera.fov, 55, 0.05);
            camera.updateProjectionMatrix();

            if (activeCameraMode === 'chase') {
                const ratio = player.progress;
                const tangent = raceCurve.getTangentAt(ratio).normalize();

                if (lookBehindActive) {
                    const camDest = player.mesh.position.clone()
                        .add(tangent.clone().multiplyScalar(2.8)) 
                        .add(new THREE.Vector3(0, 1.1, 0)); 

                    camera.position.lerp(camDest, 0.25); 
                    camera.lookAt(player.mesh.position.clone().add(new THREE.Vector3(0, 0.35, 0)));
                } else {
                    const camDest = player.mesh.position.clone()
                        .sub(tangent.clone().multiplyScalar(2.8)) 
                        .add(new THREE.Vector3(0, 1.1, 0)); 

                    camera.position.lerp(camDest, 0.25); 
                    camera.lookAt(player.mesh.position.clone().add(new THREE.Vector3(0, 0.35, 0)));
                }
            } else {
                let closestTower = cameraTowers[0];
                let minDist = 9999;
                cameraTowers.forEach(tower => {
                    const d = tower.distanceTo(player.mesh.position);
                    if (d < minDist) {
                        minDist = d; closestTower = tower;
                    }
                });

                const dir = new THREE.Vector3().subVectors(closestTower, player.mesh.position).normalize();
                const targetCamPos = player.mesh.position.clone().add(dir.multiplyScalar(13.0)); 
                targetCamPos.y += 2.0; 

                camera.position.lerp(targetCamPos, 0.1);
                camera.lookAt(player.mesh.position);
            }
        }

        // ========================================================
        // 12. HUD更新・ミニマップ
        // ========================================================
        function updateHUDAndMinimap() {
            if (!raceCurve || !gameActive || racers.length === 0 || !racers[0]) return; 

            const rankList = racers.map((r, idx) => ({
                id: idx, isPlayer: r.isPlayer, score: r.lap * 10 + r.progress
            }));
            rankList.sort((a, b) => b.score - a.score);

            const playerRank = rankList.findIndex(r => r.isPlayer) + 1;
            const suffixes = ["st", "nd", "rd", "th"];
            const sfx = playerRank <= 3 ? suffixes[playerRank - 1] : suffixes[3];
            document.getElementById('hud-rank').innerText = `${playerRank}${sfx}`;

            const player = racers[0];
            document.getElementById('hud-lap').innerText = `${Math.min(player.lap, 3)}/3`;

            if (!player.hasItem && !player.isItemRoulette) {
                document.getElementById('hud-item-ui').innerText = "";
            }

            if (player.lap > 3) {
                gameActive = false;
                const playerTimeMs = Date.now() - raceStartTime;
                showResults(playerRank, playerTimeMs);
                return; 
            }

            if (minimapCtx) {
                minimapCtx.clearRect(0, 0, 160, 160);

                minimapCtx.strokeStyle = 'rgba(30, 144, 255, 0.4)';
                minimapCtx.lineWidth = 4;
                minimapCtx.beginPath();
                
                const mapSegments = 60;
                for(let i=0; i<=mapSegments; i++) {
                    const p = raceCurve.getPointAt(i / mapSegments);
                    const mapX = 80 + p.x * 0.45;
                    const mapY = 80 + p.z * 0.45;
                    if(i===0) minimapCtx.moveTo(mapX, mapY);
                    else minimapCtx.lineTo(mapX, mapY);
                }
                minimapCtx.stroke();

                racers.forEach(r => {
                    const px = 80 + r.mesh.position.x * 0.45;
                    const py = 80 + r.mesh.position.z * 0.45;
                    
                    minimapCtx.fillStyle = r.isPlayer ? '#ff4757' : '#2ed573';
                    minimapCtx.beginPath();
                    minimapCtx.arc(px, py, r.isPlayer ? 5 : 3.5, 0, Math.PI * 2);
                    minimapCtx.fill();
                });
            }
        }

        function showResults(playerRank, playerTimeMs) {
            const table = document.getElementById('result-table');
            if (!table) return;
            table.innerHTML = "";

            const standings = racers.map((r, idx) => ({
                id: idx,
                isPlayer: r.isPlayer,
                score: r.lap * 10 + r.progress,
                name: r.isPlayer ? "YOU (Player)" : racerNames[idx]
            }));
            standings.sort((a, b) => b.score - a.score);

            standings.forEach((racerResult, index) => {
                const rankNum = index + 1;
                
                // ポイント配分（追加）
                const pointsEarned = GP_POINTS_TABLE[rankNum - 1] || 1;
                if (gpActive) {
                    gpCumulativePoints[racerResult.id] += pointsEarned;
                }

                const rankOffset = rankNum - playerRank; 
                let simulatedTimeMs = playerTimeMs + rankOffset * (2500 + Math.random() * 1500);
                if (simulatedTimeMs < 12000) simulatedTimeMs = 12000;

                const mins = Math.floor(simulatedTimeMs / 60000);
                const secs = Math.floor((simulatedTimeMs % 60000) / 1000);
                const ms = Math.floor((simulatedTimeMs % 1000) / 10);
                const timeStr = `${mins}:${secs.toString().padStart(2, '0')}.${ms.toString().padStart(2, '0')}`;

                const row = document.createElement('tr');
                row.className = racerResult.isPlayer ? "result-row player-highlight" : "result-row";
                
                const suffixes = ["st", "nd", "rd", "th"];
                const rankText = rankNum <= 3 ? `${rankNum}${suffixes[rankNum - 1]}` : `${rankNum}th`;

                // GPモード時は、獲得したポイントも行の右側に追加表示
                let pointsDisplayStr = gpActive ? ` (+${pointsEarned}pts)` : "";

                row.innerHTML = `
                    <td class="result-cell" style="font-size: 1.35rem; width: 15%;">${rankText}</td>
                    <td class="result-cell" style="width: 50%;">${racerResult.name}</td>
                    <td class="result-cell" style="width: 35%; text-align: right; font-family: monospace; font-size: 1.25rem;">${timeStr}${pointsDisplayStr}</td>
                `;
                table.appendChild(row);
            });

            // GPモードかVS(シングル)モードかでボタン配置を変更（追加）
            const retryBtn = document.getElementById('result-retry-btn');
            const menuBtn = document.getElementById('result-menu-btn');
            const gpBtn = document.getElementById('result-gp-standings-btn');

            if (gpActive) {
                retryBtn.classList.add('hidden');
                menuBtn.classList.add('hidden');
                gpBtn.classList.remove('hidden');
            } else {
                retryBtn.classList.remove('hidden');
                menuBtn.classList.remove('hidden');
                gpBtn.classList.add('hidden');
            }

            setUIState(UI_STATES.RESULT);
        }

        function triggerItemRoulette(racer) {
            if (racer.isItemRoulette) return;
            racer.isItemRoulette = true;
            
            const currentRank = getRacerRank(racer);
            const rolledItem = getRankBasedItem(currentRank);
            
            const roulettePool = Object.keys(itemEmojiMap);
            let counter = 0;
            const interval = setInterval(() => {
                const rand = roulettePool[Math.floor(Math.random() * roulettePool.length)];
                if (racer.isPlayer) {
                    document.getElementById('hud-item-ui').innerText = itemEmojiMap[rand];
                }
                counter++;
                if (counter > 8) {
                    clearInterval(interval);
                    racer.hasItem = rolledItem;
                    
                    if (rolledItem.startsWith("TRIPLE_")) {
                        racer.itemCount = 3;
                    } else {
                        racer.itemCount = 1;
                    }

                    if (racer.isPlayer) {
                        gameState.hasItem = rolledItem;
                        document.getElementById('hud-item-ui').innerText = itemEmojiMap[rolledItem];
                        playSound('item_get');
                    }
                    racer.isItemRoulette = false;
                }
            }, 100);
        }

        function updateKartColor(hex) {
            gameState.kartColor = hex;
            if (chassisMesh && chassisMesh.material) {
                chassisMesh.material.color.set(hex);
            }
            if (underglowLight) {
                underglowLight.color.set(hex);
            }
        }

        function updateWheelType(type) {
            gameState.wheelType = type;
            const newGeo = getWheelGeometry(type);
            
            if (leftWheel) {
                leftWheel.geometry.dispose();
                leftWheel.geometry = newGeo;
            }
            if (rightWheel) {
                rightWheel.geometry.dispose();
                rightWheel.geometry = newGeo;
            }
            if (backLeftWheel) {
                backLeftWheel.geometry.dispose();
                backLeftWheel.geometry = newGeo;
            }
            if (backRightWheel) {
                backRightWheel.geometry.dispose();
                backRightWheel.geometry = newGeo;
            }
        }

        // ========================================================
        // 13. DOMインターフェース一括構築
        // ========================================================
        function setupUI() {
            const colorSelector = document.getElementById('color-selector');
            colorsList.forEach(color => {
                const dot = document.createElement('div');
                dot.className = `color-dot ${color.hex === gameState.kartColor ? 'active' : ''}`;
                dot.style.backgroundColor = color.hex;
                dot.style.setProperty('--selected-color', color.hex);
                dot.dataset.color = color.hex;
                dot.addEventListener('click', () => {
                    document.querySelectorAll('.color-dot').forEach(d => d.classList.remove('active'));
                    dot.classList.add('active');
                    updateKartColor(color.hex);
                });
                colorSelector.appendChild(dot);
            });

            document.getElementById('wheel-select').addEventListener('change', (e) => {
                updateWheelType(e.target.value);
            });

            const courseGrid = document.getElementById('course-grid');
            courses.forEach((course, index) => {
                const card = document.createElement('div');
                card.className = `course-card-modern ${index === 0 ? 'active' : ''}`;
                card.innerHTML = `
                    <div>
                        <h4>${course.name}</h4>
                        <p>${course.desc}</p>
                    </div>
                    <div class="course-difficulty">${course.diff}</div>
                `;
                card.addEventListener('click', () => {
                    document.querySelectorAll('.course-card-modern').forEach(c => c.classList.remove('active'));
                    card.classList.add('active');
                    gameState.selectedCourse = index;
                });
                courseGrid.appendChild(card);
            });

            screens[UI_STATES.MAIN] = document.getElementById('home-screen');
            screens[UI_STATES.MODE] = document.getElementById('mode-screen'); // 追加
            screens[UI_STATES.SKIN] = document.getElementById('skin-screen');
            screens[UI_STATES.COURSE] = document.getElementById('course-screen');
            screens[UI_STATES.GAME] = document.getElementById('game-screen');
            screens[UI_STATES.RESULT] = document.getElementById('result-screen'); 
            screens[UI_STATES.GP_PREVIEW] = document.getElementById('gp-preview-screen'); // 追加
            screens[UI_STATES.GP_STANDINGS] = document.getElementById('gp-standings-screen'); // 追加
            screens[UI_STATES.HELP] = document.getElementById('help-modal'); 

            // ホーム画面 -> モード選択
            document.getElementById('home-start-btn').addEventListener('click', () => setUIState(UI_STATES.MODE));
            document.getElementById('home-customize-btn').addEventListener('click', () => setUIState(UI_STATES.SKIN));
            document.getElementById('skin-back-btn').addEventListener('click', () => setUIState(UI_STATES.MAIN));

            // モード選択画面制御 (追加)
            document.getElementById('mode-back-btn').addEventListener('click', () => setUIState(UI_STATES.MAIN));
            
            // VS(シングル)モード
            document.getElementById('mode-single-btn').addEventListener('click', () => {
                gpActive = false;
                setUIState(UI_STATES.COURSE);
            });

            // GP(グランプリ)モード
            document.getElementById('mode-gp-btn').addEventListener('click', () => {
                gpActive = true;
                gpCurrentRaceIndex = 0;
                gpCumulativePoints.fill(0);

                // 全30コースから重複なしのランダム4ステージを選出
                gpCourses = [];
                const courseIndicesPool = Array.from({ length: courses.length }, (_, i) => i);
                for (let i = courseIndicesPool.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [courseIndicesPool[i], courseIndicesPool[j]] = [courseIndicesPool[j], courseIndicesPool[i]];
                }
                gpCourses = courseIndicesPool.slice(0, 4);

                gameState.selectedCourse = gpCourses[0];
                setUIState(UI_STATES.GP_PREVIEW);
            });

            // コース予告画面開始
            document.getElementById('gp-preview-start-btn').addEventListener('click', () => {
                setUIState(UI_STATES.GAME);
                window.focus();
            });

            // GPランキング画面から「次へ」または「終了してメニューへ」
            document.getElementById('gp-standings-next-btn').addEventListener('click', () => {
                if (gpCurrentRaceIndex < 3) {
                    gpCurrentRaceIndex++;
                    gameState.selectedCourse = gpCourses[gpCurrentRaceIndex];
                    setUIState(UI_STATES.GP_PREVIEW);
                }
            });
            document.getElementById('gp-standings-menu-btn').addEventListener('click', () => {
                gpActive = false;
                setUIState(UI_STATES.MAIN);
            });

            // コース選択画面制御
            document.getElementById('course-back-btn').addEventListener('click', () => setUIState(UI_STATES.MODE));
            document.getElementById('course-launch-btn').addEventListener('click', () => {
                setUIState(UI_STATES.GAME);
                window.focus(); 
            });
            document.getElementById('game-exit-btn').addEventListener('click', () => {
                gpActive = false;
                setUIState(UI_STATES.MAIN);
            });

            document.getElementById('result-retry-btn').addEventListener('click', () => setUIState(UI_STATES.GAME));
            document.getElementById('result-menu-btn').addEventListener('click', () => setUIState(UI_STATES.MAIN));
            
            // リザルトからGP累積ポイント表へ遷移（追加）
            document.getElementById('result-gp-standings-btn').addEventListener('click', () => {
                setUIState(UI_STATES.GP_STANDINGS);
            });

            document.getElementById('home-help-btn').addEventListener('click', () => setUIState(UI_STATES.HELP));
            document.getElementById('help-close-btn').addEventListener('click', () => setUIState(UI_STATES.MAIN));

            window.addEventListener('keydown', (e) => {
                const key = e.key.toLowerCase();
                keys[key] = true;

                if (["arrowup", "arrowdown", "arrowleft", "arrowright", " "].includes(e.key.toLowerCase())) {
                    e.preventDefault();
                }

                if (e.key === ' ' && racers[0]) {
                    if (racers[0].canTrick && racers[0].trickTimer === 0) {
                        racers[0].trickTimer = 30;
                        playSound('trick');
                        const toast = document.getElementById('action-toast');
                        toast.classList.add('active');
                        setTimeout(() => toast.classList.remove('active'), 600);
                    }
                }

                if (key === 'q' || key === 'e') {
                    usePlayerItem();
                }

                if (key === 'c' || key === 'r') {
                    lookBehindActive = true;
                }
            });

            window.addEventListener('keyup', (e) => {
                const key = e.key.toLowerCase();
                keys[key] = false;

                if (key === 'c' || key === 'r') {
                    lookBehindActive = false;
                }
            });
        }

        // ========================================================
        // 14. Three.js ベースシステム & アニメーションループ
        // ========================================================
        function init3D() {
            const canvas = document.getElementById('bg-canvas');
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0xbae6fd);
            scene.fog = new THREE.FogExp2(0xbae6fd, 0.005);

            camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 1500);
            camera.position.copy(currentCamPos);

            renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

            const ambient = new THREE.AmbientLight(0xffffff, 0.8); 
            scene.add(ambient);

            const keyLight = new THREE.DirectionalLight(0xffffff, 1.2); 
            keyLight.position.set(20, 40, 20);
            scene.add(keyLight);

            environmentGroup = new THREE.Group();
            scene.add(environmentGroup);

            const podiumGeo = new THREE.CylinderGeometry(2.5, 2.5, 0.2, 24);
            const podiumMat = new THREE.MeshBasicMaterial({ color: 0xffcc00 }); 
            menuPodium = new THREE.Mesh(podiumGeo, podiumMat);
            menuPodium.position.y = -0.1;
            scene.add(menuPodium);

            kartGroup = new THREE.Group();
            kartGroup.position.set(0, 0.15, 0);

            const chassisGeo = new THREE.BoxGeometry(1.0, 0.2, 1.6);
            const chassisMat = new THREE.MeshStandardMaterial({
                color: gameState.kartColor,
                metalness: 0.1, 
                roughness: 0.5
            });
            chassisMesh = new THREE.Mesh(chassisGeo, chassisMat);
            chassisMesh.position.y = 0.15;
            kartGroup.add(chassisMesh);

            const wingSupportGeo = new THREE.BoxGeometry(0.1, 0.4, 0.1);
            const wingSupportMat = new THREE.MeshStandardMaterial({ color: 0x111111, roughness: 0.8 });
            const wsLeft = new THREE.Mesh(wingSupportGeo, wingSupportMat);
            wsLeft.position.set(0.35, 0.35, -0.6);
            const wsRight = wsLeft.clone();
            wsRight.position.x = -0.35;
            kartGroup.add(wsLeft, wsRight);

            const wingGeo = new THREE.BoxGeometry(1.2, 0.05, 0.3);
            const wingMesh = new THREE.Mesh(wingGeo, chassisMat);
            wingMesh.position.set(0, 0.55, -0.6);
            kartGroup.add(wingMesh);

            underglowLight = new THREE.PointLight(gameState.kartColor, 4, 3);
            underglowLight.position.set(0, -0.1, 0);
            kartGroup.add(underglowLight);

            const wheelMat = new THREE.MeshStandardMaterial({ color: 0x1e293b, roughness: 0.8 });
            const wheelGeo = getWheelGeometry(gameState.wheelType);

            leftWheelPivot = new THREE.Group();
            leftWheelPivot.position.set(0.6, 0.1, 0.5);
            leftWheel = new THREE.Mesh(wheelGeo, wheelMat);
            leftWheel.rotation.z = Math.PI / 2;
            leftWheelPivot.add(leftWheel);

            rightWheelPivot = new THREE.Group();
            rightWheelPivot.position.set(-0.6, 0.1, 0.5);
            rightWheel = new THREE.Mesh(wheelGeo, wheelMat);
            rightWheel.rotation.z = Math.PI / 2;
            rightWheelPivot.add(rightWheel);

            backLeftWheel = new THREE.Mesh(wheelGeo, wheelMat);
            backLeftWheel.rotation.z = Math.PI / 2;
            backLeftWheel.position.set(0.6, 0.1, -0.5);

            backRightWheel = backLeftWheel.clone();
            backRightWheel.position.set(-0.6, 0.1, -0.5);

            kartGroup.add(leftWheelPivot, rightWheelPivot, backLeftWheel, backRightWheel);
            scene.add(kartGroup);

            generateEnvironment(null);
            
            setupUI();
            
            animate();
        }

        function animate() {
            requestAnimationFrame(animate);

            if (particles) particles.rotation.y += 0.0006;

            if (gameState.currentState !== UI_STATES.GAME) {
                kartGroup.rotation.y += 0.005;
                kartGroup.position.set(0, 0.15, 0);

                const target = cameraTargets[gameState.currentState];
                if (target && camera) {
                    camera.position.copy(target.pos);
                    camera.lookAt(target.lookAt);
                }
            } else if (gameActive) {
                updateRacePhysics();
                updateCamera();
                updateHUDAndMinimap();
                updateWeatherParticles();
            }

            if (renderer && scene && camera) {
                renderer.render(scene, camera);
            }
        }

        window.addEventListener('resize', () => {
            if (camera && renderer) {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            }
        });

        window.onload = init3D;

        window.addEventListener('click', () => {
            if (audioCtx && audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        });
    </script>
</body>
