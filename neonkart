            // 12人のレーサー
            racers = [];
            const botColors = [0xff4757, 0x2ed573, 0xffa502, 0x1e90ff, 0x3742fa, 0xff6b81, 0xff7f50, 0x2bcbba, 0xa55eea, 0xff6348, 0x5352ed];
            
            kartGroup.rotation.set(0,0,0);
            scene.add(kartGroup);

            // ----------------------------------------------------
            // 【新規実装】プレイヤーを「最後尾(12番グリッド・インデックス11)」からスタートさせる
            // ----------------------------------------------------
            let playerStartProgress = 0.015 - (11 * 0.0035); // プレイヤーのグリッド (もっとも後方)
            let playerStartLap = 1;
            if (playerStartProgress < 0.0) {
                playerStartProgress += 1.0;
                playerStartLap = 0; // スタートライン手前なのでLapは0から
            }

            // プレイヤー
            racers.push({
                isPlayer: true,
                mesh: kartGroup,
                progress: playerStartProgress,
                lateralOffset: (11 % 2 === 0 ? 1.8 : -1.8), // 互い違いにスタッガー配置
                speed: 0.0,
                height: 0.0,
                heightVelocity: 0.0,
                driftAngle: 0.0,
                driftState: 'none', 
                driftTimer: 0,
                boostTimer: 0,
                starTimer: 0,
                spinTimer: 0,
                canTrick: false,
                trickTimer: 0,
                lap: playerStartLap,
                lastProgress: playerStartProgress,
                hasItem: null,
                isItemRoulette: false
            });

            // AI（Bot）を前に1番から11番グリッドまで順に配置
            for (let i = 0; i < 11; i++) {
                const botGroup = new THREE.Group();
                const bBody = new THREE.Mesh(new THREE.BoxGeometry(0.85, 0.2, 1.4), new THREE.MeshStandardMaterial({ color: botColors[i], metalness: 0.1, roughness: 0.5 }));
                bBody.position.y = 0.15;
                botGroup.add(bBody);

                const wGeo = new THREE.CylinderGeometry(0.3, 0.3, 0.2, 12);
                const wMat = new THREE.MeshStandardMaterial({ color: 0x1e293b, roughness: 0.8 });
                const wl = new THREE.Mesh(wGeo, wMat); wl.rotation.z = Math.PI/2; wl.position.set(0.55, 0.1, 0.45);
                const wr = wl.clone(); wr.position.x = -0.55;
                const bl = wl.clone(); bl.position.set(0.55, 0.1, -0.45);
                const br = bl.clone(); br.position.x = -0.55; // blを正確にコピーして背面右タイヤをZ=-0.45に固定
                botGroup.add(wl, wr, bl, br);

                scene.add(botGroup);

                // 各Botをグリッド上に前方から配置
                let startProgress = 0.015 - (i * 0.0035);
                let startLap = 1;
                if (startProgress < 0.0) {
                    startProgress += 1.0;
                    startLap = 0; // スタートラインの手前(Lap 0)
                }

                racers.push({
                    isPlayer: false,
                    mesh: botGroup,
                    progress: startProgress,
                    lateralOffset: (i % 2 === 0 ? 1.8 : -1.8),
                    speed: 0.0,
                    height: 0.0,
                    heightVelocity: 0.0,
                    driftAngle: 0.0,
                    boostTimer: 0,
                    starTimer: 0,
                    spinTimer: 0,
                    canTrick: false,
                    trickTimer: 0,
                    lap: startLap, // 適正補正
                    lastProgress: startProgress,
                    hasItem: null,
                    isItemRoulette: false,
                    aiThinkTimer: Math.random() * 60 
                });
            }

            // カメラ監視塔
            cameraTowers = [];
            const towersCount = 8;
            for (let i = 0; i < towersCount; i++) {
                const p = raceCurve.getPointAt(i / towersCount);
                cameraTowers.push(new THREE.Vector3(p.x, p.y + 14.0, p.z));
            }

            generateItemsAndRamps();

            // ミニマップ設定
            minimapCanvas = document.getElementById('minimap-canvas');
            minimapCtx = minimapCanvas.getContext('2d');
            minimapCanvas.width = 160;
            minimapCanvas.height = 160;
            
            gameState.hasItem = null;
            document.getElementById('hud-item-ui').innerText = ""; // 初期は完全に空表示
            document.getElementById('hud-rank').innerText = "12th"; // 初期は12位

            // 全て完了したタイミングでループを活性化させる
            gameActive = true;
            
            // 総レース走行タイム計測用
            raceStartTime = Date.now();
        }

        // コースアイテムとジャンプ台の自動生成処理
        function generateItemsAndRamps() {
            if (!raceCurve) return;
            raceItems.forEach(item => { if (item.mesh) scene.remove(item.mesh); });
            raceItems = [];
            raceRamps.forEach(ramp => { if (ramp.mesh) scene.remove(ramp.mesh); });
            raceRamps = [];

            const segments = 12; // コース上の配置ポイント数
            for (let i = 1; i < segments; i++) {
                const ratio = i / segments;
                const pos = raceCurve.getPointAt(ratio);
                const tangent = raceCurve.getTangentAt(ratio).normalize();
                const right = new THREE.Vector3().crossVectors(tangent, new THREE.Vector3(0, 1, 0)).normalize();

                if (i % 2 === 0) {
                    // アイテムボックスをコース幅に並べて配置 (幅広ロードに対応)
                    const offsets = [-4.5, 0, 4.5];
                    offsets.forEach(offset => {
                        const itemPos = pos.clone().add(right.clone().multiplyScalar(offset)).add(new THREE.Vector3(0, 0.5, 0));
                        
                        // ポップなアイテムボックス（黄色い立方体）の配置
                        const boxGeo = new THREE.BoxGeometry(0.8, 0.8, 0.8);
                        const boxMat = new THREE.MeshBasicMaterial({ color: 0xffa502 });
                        const boxMesh = new THREE.Mesh(boxGeo, boxMat);
                        boxMesh.position.copy(itemPos);
                        scene.add(boxMesh);

                        raceItems.push({
                            active: true,
                            mesh: boxMesh,
                            pos: itemPos,
                            respawnTimer: 0
                        });
                    });
                } else {
                    // ジャンプ台を配置 (少し幅を広く)
                    const rampPos = pos.clone().add(new THREE.Vector3(0, 0.1, 0));
                    
                    const rampGeo = new THREE.BoxGeometry(8.0, 0.3, 2.0);
                    const rampMat = new THREE.MeshBasicMaterial({ color: 0xff4757 });
                    const rampMesh = new THREE.Mesh(rampGeo, rampMat);
                    rampMesh.position.copy(rampPos);
                    rampMesh.lookAt(rampPos.clone().add(tangent));
                    scene.add(rampMesh);

                    raceRamps.push({
                        mesh: rampMesh,
                        pos: rampPos
                    });
                }
            }
        }

        // レース破棄
        function stopActualRace() {
            gameActive = false;
            if (roadMesh) {
                scene.remove(roadMesh);
                roadMesh.geometry.dispose();
                roadMesh.material.dispose();
                roadMesh = null;
            }

            // スタートゴールアーチとフラッグラインを綺麗にシーンから消去
            if (startArch) {
                scene.remove(startArch);
                startArch = null;
            }
            if (finishLineMesh) {
                scene.remove(finishLineMesh);
                finishLineMesh = null;
            }

            racers.forEach(r => {
                if (!r.isPlayer && r.mesh) scene.remove(r.mesh);
            });
            racers = [];

            raceItems.forEach(item => { if (item.mesh) scene.remove(item.mesh); });
            raceItems = [];

            raceRamps.forEach(ramp => { if (ramp.mesh) scene.remove(ramp.mesh); });
            raceRamps = [];

            raceBananas.forEach(b => { if (b.mesh) scene.remove(b.mesh); });
            raceBananas = [];

            raceProjectiles.forEach(p => { if (p.mesh) scene.remove(p.mesh); });
            raceProjectiles = [];

            driftSparks.forEach(s => { if (s.mesh) scene.remove(s.mesh); });
            driftSparks = [];

            if (engineOsc) {
                try {
                    engineOsc.stop();
                    engineOsc = null;
                } catch(e){}
            }
            audioCtx = null;
            raceCurve = null; 
        }

        // 画面切り替え
        function setUIState(state) {
            gameState.currentState = state;

            const target = cameraTargets[state];
            if (target && state !== UI_STATES.GAME && camera) {
                currentCamPos.copy(target.pos);
                currentCamLook.copy(target.lookAt);
                camera.position.copy(currentCamPos);
                camera.lookAt(currentCamLook);
            }

            Object.keys(screens).forEach(key => {
                if (key === state) {
                    screens[key].classList.remove('hidden');
                } else {
                    screens[key].classList.add('hidden');
                }
            });

            if (state === UI_STATES.GAME) {
                // 【不具合修正】Web Audio やその他初期化エラーに備えて頑強に try/catch で包み、ゲーム起動が必ず走るように設計
                try {
                    initAudio();
                } catch(e) {
                    console.warn("Audio Context launch skipped:", e);
                }
                try {
                    initActualRace(); 
                } catch(e) {
                    console.error("Critical error inside race initializer:", e);
                }
                if (menuPodium) menuPodium.visible = false; 
            } else {
                stopActualRace(); 
                if (menuPodium) menuPodium.visible = true; 
            }
        }

        // ========================================================
        // 7. アイテム処理 & コレクタブル更新
        // ========================================================
        function executeItemUse(racer, itemType) {
            if (itemType === "MUSHROOM") {
                racer.boostTimer = 120;
                playSound('boost');
                if (racer.isPlayer) {
                    document.getElementById('screen-filter').style.background = 'rgba(255, 165, 2, 0.15)';
                    setTimeout(() => { document.getElementById('screen-filter').style.background = 'none'; }, 500);
                }
            } else if (itemType === "STAR") {
                racer.starTimer = 300; 
                racer.boostTimer = 300;
                playSound('boost');
                if (racer.isPlayer) {
                    document.getElementById('screen-filter').style.background = 'rgba(255, 255, 255, 0.2)';
                    setTimeout(() => { document.getElementById('screen-filter').style.background = 'none'; }, 1000);
                }
            } else if (itemType === "BANANA") {
                const ratio = racer.progress;
                const pos = racer.mesh.position.clone();

                // 余分な丸い白背景カードを排除してバナナそのものを配置
                const bananaMesh = createPopItemMesh("🍌", false, '#ffffff', 2.0);
                bananaMesh.position.copy(pos);
                bananaMesh.position.y += 0.5;
                scene.add(bananaMesh);

                raceBananas.push({
                    mesh: bananaMesh,
                    pos: pos,
                    ratio: ratio,
                    offset: racer.lateralOffset,
                    age: 0,
                    maxAge: 1200 // 設置後約20秒（1200フレーム）で自然消滅
                });
            } else if (itemType === "GREEN_SHELL") {
                fireProjectile("green", racer);
            } else if (itemType === "RED_SHELL") {
                fireProjectile("red", racer);
            }
            racer.hasItem = null;
        }

        function usePlayerItem() {
            if (!gameState.hasItem || gameState.isItemRoulette) return;
            executeItemUse(racers[0], gameState.hasItem);
            gameState.hasItem = null;
            // 使用後はアイテムボックス表示を空にする
            document.getElementById('hud-item-ui').innerText = "";
        }

        function fireProjectile(type, owner) {
            if (!raceCurve) return; 
            const ratio = owner.progress;
            
            // bgRound = false により余分な白背景を完璧に排除した「甲羅単体」の生成
            const pMesh = createPopItemMesh("🐢", false, '#ffffff', 2.2);
            if (type === "red") {
                // 赤甲羅は赤色にカラーティント
                pMesh.material.color.setHex(0xff4757);
            } else {
                // 緑甲羅は緑色にカラーティント
                pMesh.material.color.setHex(0x2ed573);
            }
            pMesh.position.copy(owner.mesh.position);
            scene.add(pMesh);

            let targetRacer = null;
            if (type === "red") {
                const rankList = racers.map((r, idx) => ({ id: idx, score: r.lap * 10 + r.progress }));
                rankList.sort((a,b) => b.score - a.score);
                const myRankIdx = rankList.findIndex(r => racers[r.id] === owner);
                if (myRankIdx > 0) {
                    targetRacer = racers[rankList[myRankIdx - 1].id]; 
                }
            }

            raceProjectiles.push({
                mesh: pMesh,
                progress: ratio + 0.005, 
                lateralOffset: owner.lateralOffset,
                type: type,
                owner: owner,
                target: targetRacer,
                speed: 0.45, 
                active: true
            });
        }

        // ロケットスタート成功時の派手な火炎バーストエフェクトとフラッシュ
