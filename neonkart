                const wr = wl.clone(); wr.position.x = -0.55;
                const bl = wl.clone(); bl.position.set(0.55, 0.1, -0.45);
                const br = bl.clone(); br.position.x = -0.55; 
                botGroup.add(wl, wr, bl, br);

                scene.add(botGroup);

                let startProgress = 0.015 - (i * 0.0035);
                let startLap = 1;
                if (startProgress < 0.0) {
                    startProgress += 1.0;
                    startLap = 0; 
                }

                racers.push({
                    isPlayer: false,
                    mesh: botGroup,
                    progress: startProgress,
                    lateralOffset: (i % 2 === 0 ? 1.8 : -1.8),
                    speed: 0.0,
                    height: 0.0,
                    heightVelocity: 0.0,
                    driftAngle: 0.0,
                    boostTimer: 0,
                    starTimer: 0,
                    spinTimer: 0,
                    lightningTimer: 0, 
                    goldenTimer: 0,    
                    itemCount: 1,      
                    canTrick: false,
                    trickTimer: 0,
                    lap: startLap, 
                    lastProgress: startProgress,
                    hasItem: null,
                    isItemRoulette: false,
                    aiThinkTimer: Math.random() * 60 
                });
            }

            cameraTowers = [];
            const towersCount = 8;
            for (let i = 0; i < towersCount; i++) {
                const p = raceCurve.getPointAt(i / towersCount);
                cameraTowers.push(new THREE.Vector3(p.x, p.y + 14.0, p.z));
            }

            generateItemsAndRamps();

            // ミニマップ設定
            minimapCanvas = document.getElementById('minimap-canvas');
            minimapCtx = minimapCanvas.getContext('2d');
            minimapCanvas.width = 160;
            minimapCanvas.height = 160;
            
            gameState.hasItem = null;
            document.getElementById('hud-item-ui').innerText = ""; 
            document.getElementById('hud-rank').innerText = "12th"; 

            gameActive = true;
            raceStartTime = Date.now();
        }

        function generateItemsAndRamps() {
            if (!raceCurve) return;
            raceItems.forEach(item => { if (item.mesh) scene.remove(item.mesh); });
            raceItems = [];
            raceRamps.forEach(ramp => { if (ramp.mesh) scene.remove(ramp.mesh); });
            raceRamps = [];

            const segments = 12; 
            for (let i = 1; i < segments; i++) {
                const ratio = i / segments;
                const pos = raceCurve.getPointAt(ratio);
                const tangent = raceCurve.getTangentAt(ratio).normalize();
                const right = new THREE.Vector3().crossVectors(tangent, new THREE.Vector3(0, 1, 0)).normalize();

                if (i % 2 === 0) {
                    const offsets = [-4.5, 0, 4.5];
                    offsets.forEach(offset => {
                        const itemPos = pos.clone().add(right.clone().multiplyScalar(offset)).add(new THREE.Vector3(0, 0.5, 0));
                        
                        const boxGeo = new THREE.BoxGeometry(0.8, 0.8, 0.8);
                        const boxMat = new THREE.MeshBasicMaterial({ color: 0xffa502 });
                        const boxMesh = new THREE.Mesh(boxGeo, boxMat);
                        boxMesh.position.copy(itemPos);
                        scene.add(boxMesh);

                        raceItems.push({
                            active: true,
                            mesh: boxMesh,
                            pos: itemPos,
                            respawnTimer: 0
                        });
                    });
                } else {
                    const rampPos = pos.clone().add(new THREE.Vector3(0, 0.1, 0));
                    
                    const rampGeo = new THREE.BoxGeometry(8.0, 0.3, 2.0);
                    const rampMat = new THREE.MeshBasicMaterial({ color: 0xff4757 });
                    const rampMesh = new THREE.Mesh(rampGeo, rampMat);
                    rampMesh.position.copy(rampPos);
                    rampMesh.lookAt(rampPos.clone().add(tangent));
                    scene.add(rampMesh);

                    raceRamps.push({
                        mesh: rampMesh,
                        pos: rampPos
                    });
                }
            }
        }

