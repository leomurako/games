        // コーススプラインの数理自動生成
        function createCourseSpline(index) {
            const points = [];
            const segments = 24;
            const radius = 150;
            
            for (let i = 0; i < segments; i++) {
                const angle = (i / segments) * Math.PI * 2;
                let r = radius;
                let x = Math.cos(angle) * r;
                let z = Math.sin(angle) * r;
                let y = 0;

                switch(index) {
                    case 0: // Mario Circuit
                        r += Math.sin(angle * 2) * 20;
                        x = Math.cos(angle) * r; z = Math.sin(angle) * r;
                        break;
                    case 1: // Desert Ruins
                        r += Math.cos(angle * 3) * 15;
                        x = Math.cos(angle) * r; z = Math.sin(angle) * r;
                        y = Math.sin(angle * 12) * 5; 
                        break;
                    case 2: // Peach Garden
                        r += Math.sin(angle * 5) * 30;
                        x = Math.cos(angle) * r; z = Math.sin(angle) * r;
                        break;
                    case 3: // DK Summit
                        r += Math.cos(angle * 2) * 20;
                        x = Math.cos(angle) * r; z = Math.sin(angle) * r;
                        y = Math.sin(angle) * 30;
                        break;
                    case 4: // Bowser Castle
                        const factor = 0.8 + 0.2 * Math.sin(angle * 4);
                        x = Math.cos(angle) * r * factor; z = Math.sin(angle) * r * factor;
                        break;
                    case 5: // Oasis Expressway
                        r += Math.sin(angle * 3) * 20;
                        x = Math.cos(angle) * r; z = Math.sin(angle) * r;
                        y = Math.cos(angle * 3) * 8;
                        break;
                    case 6: // Sweet Sweet Kingdom
                        const loopFactor = 1.0 + 0.3 * Math.sin(angle);
                        r = radius * loopFactor;
                        x = Math.cos(angle) * r; z = Math.sin(angle) * r;
                        y = Math.sin(angle * 2) * 12;
                        break;
                    case 7: // Maple Treeway
                        r += Math.sin(angle * 6) * 25;
                        x = Math.cos(angle) * r; z = Math.sin(angle) * r;
                        y = Math.cos(angle * 15);
                        break;
                    case 8: // Grumble Volcano
                        r += Math.sin(angle * 4) * 35;
                        x = Math.cos(angle) * r; z = Math.sin(angle) * r;
                        y = Math.sin(angle * 3) * 12;
                        break;
                    case 9: // Rainbow Road
                        r += Math.sin(angle * 2) * 25;
                        x = Math.cos(angle) * r; z = Math.sin(angle) * r;
                        y = Math.sin(angle) * 20;
                        break;
                }
                points.push(new THREE.Vector3(x, y, z));
            }
            const spline = new THREE.CatmullRomCurve3(points);
            spline.closed = true;
            return spline;
        }

        // ========================================================
        // 5. ジオメトリ生成・ロードテクスチャ・ホイール
        // ========================================================
        function createFlatRoadGeometry(curve, width, segments = 200) {
            const vertices = [];
            const indices = [];
            const uvs = [];

            for (let i = 0; i <= segments; i++) {
                const t = i / segments;
                const pos = curve.getPointAt(t);
                const tangent = curve.getTangentAt(t).normalize();
                
                const right = new THREE.Vector3().crossVectors(tangent, new THREE.Vector3(0, 1, 0)).normalize();
                
                const leftPos = pos.clone().add(right.clone().multiplyScalar(width / 2));
                const rightPos = pos.clone().sub(right.clone().multiplyScalar(width / 2));

                vertices.push(leftPos.x, leftPos.y, leftPos.z);
                vertices.push(rightPos.x, rightPos.y, rightPos.z);

                uvs.push(0, t * 40); 
                uvs.push(1, t * 40);

                if (i < segments) {
                    const a = i * 2;
                    const b = i * 2 + 1;
                    const c = (i + 1) * 2;
                    const d = (i + 1) * 2 + 1;

                    indices.push(a, b, c);
                    indices.push(b, d, c);
                }
            }

            const geo = new THREE.BufferGeometry();
            geo.setAttribute('position', new THREE.Float32BufferAttribute(vertices, 3));
            geo.setAttribute('uv', new THREE.Float32BufferAttribute(uvs, 2));
            geo.setIndex(indices);
            geo.computeVertexNormals();
            return geo;
        }

        function createPopRoadTexture() {
            const canvas = document.createElement('canvas');
            canvas.width = 128;
            canvas.height = 256;
            const ctx = canvas.getContext('2d');
            
            ctx.fillStyle = '#475569';
            ctx.fillRect(0, 0, 128, 256);
            
            ctx.fillStyle = '#ff4757';
            ctx.fillRect(0, 0, 14, 256);
            ctx.fillRect(114, 0, 14, 256);
            
            ctx.fillStyle = '#ffffff';
            for (let y = 0; y < 256; y += 32) {
                ctx.fillRect(0, y, 14, 16);
                ctx.fillRect(114, y + 16, 14, 16);
            }
            
            ctx.fillStyle = '#ffa502';
            for (let y = 0; y < 256; y += 64) {
                ctx.fillRect(62, y, 4, 32);
            }
            
            const texture = new THREE.CanvasTexture(canvas);
            texture.wrapS = THREE.RepeatWrapping;
            texture.wrapT = THREE.RepeatWrapping;
            texture.needsUpdate = true;
            return texture;
        }

        // 【修正】本家と同じ白黒のチェッカーフラッグゴールライン用テクスチャの動的生成
        function createCheckeredTexture() {
            const canvas = document.createElement('canvas');
            canvas.width = 128;
            canvas.height = 32;
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, 128, 32);
            ctx.fillStyle = '#222222';
            for (let x = 0; x < 128; x += 16) {
                for (let y = 0; y < 32; y += 16) {
                    if (((x / 16) + (y / 16)) % 2 === 0) {
                        ctx.fillRect(x, y, 16, 16);
                    }
                }
            }
            const texture = new THREE.CanvasTexture(canvas);
            texture.wrapS = THREE.RepeatWrapping;
            texture.wrapT = THREE.RepeatWrapping;
            texture.needsUpdate = true;
            return texture;
        }

        function createEmojiTexture(emoji, bgRound = true, bgColor = '#ffffff') {
            const canvas = document.createElement('canvas');
            canvas.width = 128;
            canvas.height = 128;
            const ctx = canvas.getContext('2d');

            if (bgRound) {
                ctx.fillStyle = bgColor;
                ctx.beginPath();
                ctx.arc(64, 64, 56, 0, Math.PI * 2);
                ctx.fill();
                ctx.lineWidth = 6;
                ctx.strokeStyle = '#222222';
                ctx.stroke();
            }

            ctx.font = '76px sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(emoji, 64, 68); 

            const texture = new THREE.CanvasTexture(canvas);
            texture.needsUpdate = true;
            return texture;
        }

        function createPopItemMesh(emoji, bgRound = true, bgColor = '#ffffff', scale = 2.4) {
