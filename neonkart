        function updateRacePhysics() {
            // 安全対策：もしコースやプレイヤーカートが生成されていなければ処理をスキップ
            if (!raceCurve || !gameActive || racers.length === 0 || !racers[0]) return;

            // ----------------------------------------------------
            // 3-2-1 カウントダウン & ロケットスタート制御
            // ----------------------------------------------------
            if (raceIntroState === 'countdown') {
                countdownTimer--;

                // スタート前のアクセル入力時間の記録
                if (keys['w'] || keys['arrowup']) {
                    if (accelPressedTime === -1) {
                        accelPressedTime = countdownTimer; // 180から減算中のフレームを記録
                    }
                }

                const overlay = document.getElementById('countdown-overlay');
                if (overlay) {
                    if (countdownTimer > 120) {
                        overlay.innerText = "3";
                        overlay.style.color = "#ff4757";
                        if (countdownTimer === 179) playCountdownBeep(false);
                    } else if (countdownTimer > 60) {
                        overlay.innerText = "2";
                        overlay.style.color = "#ffa502";
                        if (countdownTimer === 119) playCountdownBeep(false);
                    } else if (countdownTimer > 0) {
                        overlay.innerText = "1";
                        overlay.style.color = "#2ed573";
                        if (countdownTimer === 59) playCountdownBeep(false);
                    } else if (countdownTimer === 0) {
                        overlay.innerText = "GO!";
                        overlay.style.color = "#1e90ff";
                        playCountdownBeep(true);

                        // ロケットスタート判定
                        if (accelPressedTime > 120) {
                            // 3の時点でフライング気味にアクセルを押してしまっていた場合はエンジンブロー（スピン）
                            racers[0].spinTimer = 90; 
                            playSound('hit');
                        } else if (accelPressedTime > 0 && accelPressedTime <= 120) {
                            // 2～1のタイミングよく押した段階により強力ブースト
                            if (accelPressedTime >= 60 && accelPressedTime <= 120) {
                                racers[0].boostTimer = 160; // スーパーロケットスタート
                                triggerRocketStartBurst(racers[0].mesh.position);
                            } else {
                                racers[0].boostTimer = 80;  // 通常ロケットスタート
                                triggerRocketStartBurst(racers[0].mesh.position);
                            }
                            playSound('boost');
                        }
                        
                        raceIntroState = 'racing';
                        setTimeout(() => { overlay.innerText = ""; }, 1000);
                    }
                }

                // カウントダウン中はグリッド上に並べるのみで物理は進めない
                racers.forEach(racer => {
                    applySplinePlacement(racer);
                });
                return;
            }

            const trackLength = raceCurve.getLength();

            racers.forEach((racer, index) => {
                if (racer.starTimer > 0) {
                    const h = (Date.now() % 500) / 500;
                    racer.mesh.children[0].material.color.setHSL(h, 1.0, 0.5); 
                } else if (racer.isPlayer) {
                    racer.mesh.children[0].material.color.set(gameState.kartColor); 
                }

                if (racer.spinTimer > 0) {
                    racer.spinTimer--;
                    racer.speed *= 0.85; 
                    racer.mesh.rotation.y += 0.45; 
                    if (racer.spinTimer === 0) racer.mesh.rotation.y = 0;
                    applySplinePlacement(racer);
                    return;
                }

                let targetSpeed = 0.0;
                let accel = 0.0025;
                let decel = 0.004;

                const hasStar = racer.starTimer > 0;
                const hasBoost = racer.boostTimer > 0;

                if (racer.starTimer > 0) racer.starTimer--;
                if (racer.boostTimer > 0) racer.boostTimer--;

                let maxSpeedBase = racer.isPlayer ? 0.35 : 0.31;
                if (hasBoost) maxSpeedBase = 0.58; 
                if (hasStar) maxSpeedBase = 0.52;

                if (racer.isPlayer) {
                    if (keys['w'] || keys['arrowup']) {
                        targetSpeed = maxSpeedBase;
                    } else if (keys['s'] || keys['arrowdown']) {
                        targetSpeed = -0.15; 
                    }

                    // DとAの旋回方向の極性を適正値（A=左、D=右）に設定
                    let steeringInput = 0;
                    if (keys['a'] || keys['arrowleft']) steeringInput = -1; // 左旋回 (-1)
                    if (keys['d'] || keys['arrowright']) steeringInput = 1;  // 右旋回 (1)

                    // 前輪の旋回方向（ピボットの回転方向）を物理進行方向と100%一致するようにインバート
                    if (leftWheelPivot && rightWheelPivot) {
                        let targetWheelYaw = 0;
                        if (steeringInput > 0) targetWheelYaw = -0.45;      // Dキー（右入力）でタイヤを右（負のY回転）に向ける
                        else if (steeringInput < 0) targetWheelYaw = 0.45;  // Aキー（左入力）でタイヤを左（正のY回転）に向ける
                        leftWheelPivot.rotation.y = THREE.MathUtils.lerp(leftWheelPivot.rotation.y, targetWheelYaw, 0.15);
                        rightWheelPivot.rotation.y = THREE.MathUtils.lerp(rightWheelPivot.rotation.y, targetWheelYaw, 0.15);
                    }

                    // 曲がっている最中かつ走行中のみドリフトを受け付ける
                    if (steeringInput !== 0) {
                        if (keys[' '] && racer.height === 0 && Math.abs(racer.speed) > 0.1) {
                            if (racer.driftState === 'none') {
                                // A（マイナス）で左ドリフト、D（プラス）で右ドリフトを正確に発動
                                racer.driftState = steeringInput > 0 ? 'right' : 'left';
                                racer.driftTimer = 0;
                                // ドリフト開始時の「ホップ（小ジャンプ）」
                                racer.heightVelocity = 3.2; 
                                racer.height = 0.05; 
                            }
                        }
                    }

                    // ----------------------------------------------------
                    // アウト側への慣性スライドを大幅に強化したドリフト制御
                    // ----------------------------------------------------
                    if (racer.driftState !== 'none') {
                        // ドリフト中はレスポンス（ステアリング応答）を重くし、慣性重視の操作感に (lerp: 0.08 -> 0.04)
                        if (racer.steerValue === undefined) racer.steerValue = 0;
                        racer.steerValue = THREE.MathUtils.lerp(racer.steerValue, steeringInput, 0.04);

                        // 完全に静止した状態でスライドするのを防止するため、速度比例係数を算出
                        let driftSpeedFactor = Math.max(0, Math.min(1.5, Math.abs(racer.speed) / 0.35));

                        // アウト側への遠心スライド力の適用（速度比例）
                        if (racer.driftState === 'left') {
                            // 左ドリフト：カーブは左。アウト側は右（+lateralOffset方向）へ強くスライドする
                            let slidePower = 0.14;
                            if (steeringInput < 0) { // Aを押してさらにイン（左）に切り込んでいる
                                slidePower -= 0.09;
                            } else if (steeringInput > 0) { // Dを押してアウト（右）に逆ステア
                                slidePower += 0.08;
                            }
                            racer.lateralOffset += slidePower * driftSpeedFactor;
                            // 曲がる方向へお尻を少し振り、鼻先をイン（左 = 正の回転）に向けさせます
                            racer.driftAngle = 0.28; 
                        } else if (racer.driftState === 'right') {
                            // 右ドリフト：カーブは右。アウト側は左（-lateralOffset方向）へ強くスライドする
                            let slidePower = 0.14;
                            if (steeringInput > 0) { // Dを押してさらにイン（右）に切り込んでいる
                                slidePower -= 0.09;
                            } else if (steeringInput < 0) { // Aを押してアウト（左）に逆ステア
                                slidePower += 0.08;
                            }
                            racer.lateralOffset -= slidePower * driftSpeedFactor;
                            // 曲がる方向へお尻を少し振り、鼻先をイン（右 = 負の回転）に向けさせます
                            racer.driftAngle = -0.28; 
                        }

                        // 【実装】ドリフトボタン（スペースキー）を離した瞬間にミニターボ解放
                        if (!keys[' ']) {
                            resolveMiniTurbo(racer);
                        }
                    } else {
                        // ----------------------------------------------------
                        // Wキー（アクセル入力中）など移動中のみ左右に動くように変更
                        // 停止中（AやDを単体で押しただけ）はスライドしないように、速度に比例してオフセットを増減
                        // ----------------------------------------------------
                        let steerSpeedFactor = racer.speed * 2.85; // 停止時は 0 となり、左右移動しない

                        if (steeringInput !== 0) {
                            if (racer.steerValue === undefined) racer.steerValue = 0;
                            racer.steerValue = THREE.MathUtils.lerp(racer.steerValue, steeringInput, 0.09);
                            racer.lateralOffset += racer.steerValue * 0.18 * steerSpeedFactor; 
                            
                            // 通常旋回中も、お尻がわずかに外側に流れ、鼻先が曲がる方向へ少し向く（ロールではなくYaw方向）挙動の実装
                            racer.driftAngle = -steeringInput * 0.15; // A(左旋回=-1)のとき正(0.15)=左向き / D(right=1)のとき負(-0.15)=右向き
                        } else {
                            if (racer.steerValue === undefined) racer.steerValue = 0;
                            racer.steerValue = THREE.MathUtils.lerp(racer.steerValue, 0, 0.1);
                            racer.lateralOffset += racer.steerValue * 0.18 * steerSpeedFactor;
                            racer.driftAngle *= 0.8;
                        }
                    }

                    // ----------------------------------------------------
                    // ドリフトの火花を3段階（青 ➔ 赤 ➔ 紫）に拡張
                    // ----------------------------------------------------
                    if (racer.driftState !== 'none' && racer.height === 0) {
                        racer.driftTimer++;

                        let sparkColor = null;
                        if (racer.driftTimer >= 145) {
                            sparkColor = 0xa55eea; // 紫（ウルトラミニターボ）
                        } else if (racer.driftTimer >= 85) {
                            sparkColor = 0xff4757; // 赤（スーパーミニターボ）
                        } else if (racer.driftTimer >= 35) {
                            sparkColor = 0x00f0ff; // 青（ミニターボ）
                        }

                        if (sparkColor) {
                            const offsetSign = racer.driftState === 'left' ? 1 : -1;
                            const sparkPos = racer.mesh.position.clone()
                                .add(new THREE.Vector3(offsetSign * 0.5, 0, -0.4));
                            spawnDriftSpark(sparkPos, sparkColor);
                        }
                    }

                } else {
                    // AI (Bot) 処理
                    targetSpeed = maxSpeedBase * (0.83 + Math.sin(Date.now() * 0.001 + index) * 0.17);
                    
                    racer.aiThinkTimer--;
                    if (racer.aiThinkTimer <= 0) {
                        racer.aiThinkTimer = 30 + Math.random() * 40; 

                        if (racer.hasItem && !racer.isItemRoulette) {
                            if (racer.hasItem === "MUSHROOM" || racer.hasItem === "STAR") {
                                executeItemUse(racer, racer.hasItem);
                            } else if (racer.hasItem === "BANANA") {
                                const anyoneBehind = racers.some(other => other !== racer && (racer.progress - other.progress) > 0 && (racer.progress - other.progress) < 0.05);
                                if (anyoneBehind) executeItemUse(racer, "BANANA");
                            } else {
                                const anyoneAhead = racers.some(other => other !== racer && (other.progress - racer.progress) > 0 && (other.progress - racer.progress) < 0.12);
                                if (anyoneAhead) executeItemUse(racer, racer.hasItem);
                            }
                        }
                    }

                    let dodgeOffset = 0;
                    raceBananas.forEach(banana => {
                        const distToBanana = (banana.ratio - racer.progress + 1.0) % 1.0;
                        if (distToBanana > 0 && distToBanana < 0.08) {
                            const latDiff = Math.abs(racer.lateralOffset - banana.offset);
                            if (latDiff < 2.0) {
                                dodgeOffset = racer.lateralOffset > banana.offset ? 1.8 : -1.8;
                            }
                        }
                    });

                    // 道路幅が広くなったため、AIのライン取りの振れ幅を大きく調整 (2.8 -> 5.0)
                    const baseLine = Math.sin(racer.progress * 18 + index) * 5.0; 
                    const finalTargetLine = baseLine + dodgeOffset;
                    racer.lateralOffset += (finalTargetLine - racer.lateralOffset) * 0.05;
                }

                if (racer.speed < targetSpeed) {
                    racer.speed += accel;
                    if (racer.speed > targetSpeed) racer.speed = targetSpeed;
                } else {
                    racer.speed -= decel;
                    if (racer.speed < targetSpeed) racer.speed = targetSpeed;
                }

                if (Math.abs(racer.lateralOffset) > ROAD_WIDTH / 2) {
                    racer.speed *= 0.92; 
                    racer.lateralOffset = Math.max(-ROAD_WIDTH/2 - 0.5, Math.min(ROAD_WIDTH/2 + 0.5, racer.lateralOffset));
                }

                racer.lastProgress = racer.progress;
                racer.progress += racer.speed / trackLength;

                if (racer.progress >= 1.0) {
                    racer.progress -= 1.0;
                    racer.lap++;
                } else if (racer.progress < 0.0) {
                    racer.progress += 1.0;
                    racer.lap--; // 逆走時の減算処理
                }

                if (racer.height > 0 || racer.heightVelocity !== 0) {
                    racer.heightVelocity -= 0.3; 
                    racer.height += racer.heightVelocity * 0.05;

                    if (racer.height <= 0) {
                        racer.height = 0;
                        racer.heightVelocity = 0;
                        if (racer.trickTimer > 0) {
                            racer.boostTimer = 85; 
                            racer.trickTimer = 0;
                            playSound('boost');
                            if (racer.isPlayer) {
                                document.getElementById('screen-filter').style.background = 'rgba(255, 165, 2, 0.12)';
                                setTimeout(() => { document.getElementById('screen-filter').style.background = 'none'; }, 300);
                            }
                        }
                        racer.canTrick = false;
                    }
                }

                if (racer.trickTimer > 0) racer.trickTimer--;

                applySplinePlacement(racer);
            });

            updateEngineSound(racers[0].speed);

            // コライダ押し出し
            for (let i = 0; i < racers.length; i++) {
                for (let j = i + 1; j < racers.length; j++) {
                    const r1 = racers[i];
                    const r2 = racers[j];
                    const dist = r1.mesh.position.distanceTo(r2.mesh.position);
                    if (dist < 1.4) {
                        const pushForce = 0.2;
                        const dir = new THREE.Vector3().subVectors(r1.mesh.position, r2.mesh.position).normalize();
                        r1.lateralOffset += dir.x * pushForce;
                        r2.lateralOffset -= dir.x * pushForce;

                        const tempSpeed = r1.speed;
                        r1.speed = r2.speed * 0.8;
                        r2.speed = tempSpeed * 0.8;
                    }
                }
            }

            updateCollectiblesAndProjectiles();
            updateDriftSparks();
        }

        // 3段階ミニターボの解放時間の振り分け
        function resolveMiniTurbo(racer) {
            if (racer.driftTimer > 145) { 
                racer.boostTimer = 180; // ウルトラミニターボ (紫色の最高ダッシュ)
                playSound('boost');
                triggerBoostVisualEffect();
            } else if (racer.driftTimer > 85) { 
                racer.boostTimer = 110; // スーパーミニターボ (赤)
                playSound('boost');
                triggerBoostVisualEffect();
            } else if (racer.driftTimer > 35) { 
                racer.boostTimer = 50;  // ミニターボ (青)
                playSound('boost');
                triggerBoostVisualEffect();
            }
            racer.driftState = 'none';
            racer.driftTimer = 0;
        }

        function updateCollectiblesAndProjectiles() {
            if (!raceCurve) return;

            const trackLength = raceCurve.getLength();

            // アイテムBOX
            raceItems.forEach(item => {
                if (item.active) {
                    if (item.mesh) {
                        item.mesh.rotation.y += 0.05; 
                    }
                    racers.forEach(racer => {
                        const dist = racer.mesh.position.distanceTo(item.pos);
                        if (dist < 1.8) {
                            item.active = false;
                            item.mesh.visible = false;
                            item.respawnTimer = 300; 
                            triggerItemRoulette(racer);
                        }
                    });
                } else {
                    item.respawnTimer--;
                    if (item.respawnTimer <= 0) {
                        item.active = true;
                        item.mesh.visible = true;
                    }
                }
            });

            // ジャンプ台
            raceRamps.forEach(ramp => {
                racers.forEach(racer => {
                    const dist = racer.mesh.position.distanceTo(ramp.pos);
                    if (dist < 2.5 && racer.height === 0) {
                        racer.heightVelocity = 7.5;
                        racer.height = 0.15;
                        racer.canTrick = true;
                    }
                });
            });

            // バナナ
            for (let idx = raceBananas.length - 1; idx >= 0; idx--) {
                const b = raceBananas[idx];
                b.age++;
                if (b.mesh) b.mesh.rotation.y += 0.02; 
                
                let triggered = false;
                // 当たり判定
                for (let j = 0; j < racers.length; j++) {
                    const racer = racers[j];
                    if (racer.spinTimer === 0) {
                        const dist = racer.mesh.position.distanceTo(b.pos);
                        if (dist < 1.5) {
                            racer.spinTimer = 60; 
                            playSound('hit');
                            scene.remove(b.mesh);
                            raceBananas.splice(idx, 1);
                            triggered = true;
                            break;
                        }
                    }
                }

                // 被弾せず、かつ規定寿命（20秒）を超えた場合は自然消滅
                if (!triggered && b.age >= b.maxAge) {
                    scene.remove(b.mesh);
                    raceBananas.splice(idx, 1);
                }
            }

            // 甲羅
            for (let i = raceProjectiles.length - 1; i >= 0; i--) {
                const p = raceProjectiles[i];
                p.progress += p.speed / trackLength;

                const ratio = p.progress % 1.0;
                const pos = raceCurve.getPointAt(ratio);
                const tangent = raceCurve.getTangentAt(ratio).normalize();
                const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize();

                if (p.type === "red" && p.target) {
                    p.lateralOffset += (p.target.lateralOffset - p.lateralOffset) * 0.12;
                }

                const finalPos = pos.clone().add(normal.multiplyScalar(p.lateralOffset)).add(new THREE.Vector3(0, 0.4, 0));
                p.mesh.position.copy(finalPos);
                p.mesh.rotation.y += 0.05; 

                let exploded = false;
                for (let j = 0; j < racers.length; j++) {
                    const racer = racers[j];
                    if (racer !== p.owner) {
                        const dist = p.mesh.position.distanceTo(racer.mesh.position);
                        if (dist < 1.8) {
                            racer.spinTimer = 80; 
                            playSound('hit');
                            exploded = true;
                            break;
                        }
                    }
                }

                if (exploded || p.progress > 2.0) {
                    scene.remove(p.mesh);
                    raceProjectiles.splice(i, 1);
                }
            }
        }

        function applySplinePlacement(racer) {
            if (!raceCurve) return; 
            const ratio = (racer.progress + 1.0) % 1.0;
            const pos = raceCurve.getPointAt(ratio);
            const tangent = raceCurve.getTangentAt(ratio).normalize();
            
            const right = new THREE.Vector3().crossVectors(tangent, new THREE.Vector3(0, 1, 0)).normalize();

            const finalPos = pos.clone()
                .add(right.clone().multiplyScalar(racer.lateralOffset))
                .add(new THREE.Vector3(0, racer.height + 0.15, 0));

            racer.mesh.position.copy(finalPos);

            if (racer.spinTimer === 0) {
                // ----------------------------------------------------
                // 高低差における車体の反転や、Euler回転変換バグによる真横・カメラ向き反転バグを解決
                // tangent（進行方向）のY（上下）成分を 0 に投影した完全に水平なベクトル(XZ平面)を作成します
                // ----------------------------------------------------
                const flatTangent = new THREE.Vector3(tangent.x, 0, tangent.z).normalize();
                const flatTarget = finalPos.clone().add(flatTangent);
                
                // 水平ターゲットに向けて lookAt することで、純粋なY軸旋回（Yaw）のみを計算
                racer.mesh.lookAt(flatTarget);

                if (racer.trickTimer > 0) {
                    racer.mesh.rotation.x += 0.25; 
                } else if (racer.isPlayer) {
                    // ドリフト時は、計算された適正な前方水平方向に対して、ドリフト用の旋回傾き角度(Y)のみをオフセット
                    racer.mesh.rotation.y += racer.driftAngle;
                }
            }
        }

        // ========================================================
        // 8. カメラワーク更新
        // ========================================================
        function updateCamera() {
            if (racers.length === 0 || !racers[0]) return; 
            const player = racers[0];
            if (!player || !camera || !raceCurve || !gameActive) return;

            // スピード感によるFOV値のスムーズな線形補間（戻し）
            camera.fov = THREE.MathUtils.lerp(camera.fov, 55, 0.05);
            camera.updateProjectionMatrix();

            if (activeCameraMode === 'chase') {
                const ratio = player.progress;
                const tangent = raceCurve.getTangentAt(ratio).normalize();

                if (lookBehindActive) {
                    // ミラーカメラ
                    const camDest = player.mesh.position.clone()
                        .add(tangent.clone().multiplyScalar(2.8)) 
                        .add(new THREE.Vector3(0, 1.1, 0)); 

                    camera.position.lerp(camDest, 0.25); 
                    camera.lookAt(player.mesh.position.clone().add(new THREE.Vector3(0, 0.35, 0)));
                } else {
                    // 真後ろ超至近距離カメラ
                    const camDest = player.mesh.position.clone()
                        .sub(tangent.clone().multiplyScalar(2.8)) 
                        .add(new THREE.Vector3(0, 1.1, 0)); 

                    // 【不具合修正】引数の渡し方を修正し、NaNによるカメラ消失を防ぎました
                    camera.position.lerp(camDest, 0.25); 
                    camera.lookAt(player.mesh.position.clone().add(new THREE.Vector3(0, 0.35, 0)));
                }
            } else {
                // TVドローン接近カメラ（自車から13メートル内をキープ）
                let closestTower = cameraTowers[0];
                let minDist = 9999;
                cameraTowers.forEach(tower => {
                    const d = tower.distanceTo(player.mesh.position);
                    if (d < minDist) {
                        minDist = d; closestTower = tower;
                    }
                });

                const dir = new THREE.Vector3().subVectors(closestTower, player.mesh.position).normalize();
                const targetCamPos = player.mesh.position.clone().add(dir.multiplyScalar(13.0)); 
                targetCamPos.y += 2.0; 

                camera.position.lerp(targetCamPos, 0.1);
                camera.lookAt(player.mesh.position);
            }
        }

        // ========================================================
        // 9. HUD更新・ミニマップ
        // ========================================================
        function updateHUDAndMinimap() {
            if (!raceCurve || !gameActive || racers.length === 0 || !racers[0]) return; 

            // リアルタイムに周回数(lap)とスプライン進行度(progress)を合算したスコアから全員の順位を継続更新
            const rankList = racers.map((r, idx) => ({
                id: idx, isPlayer: r.isPlayer, score: r.lap * 10 + r.progress
            }));
            rankList.sort((a, b) => b.score - a.score);

            const playerRank = rankList.findIndex(r => r.isPlayer) + 1;
            const suffixes = ["st", "nd", "rd", "th"];
            const sfx = playerRank <= 3 ? suffixes[playerRank - 1] : suffixes[3];
            document.getElementById('hud-rank').innerText = `${playerRank}${sfx}`;

            const player = racers[0];
            document.getElementById('hud-lap').innerText = `${Math.min(player.lap, 3)}/3`;

            // アイテムがない時、何も表示しないようにする
            if (!player.hasItem && !player.isItemRoulette) {
                document.getElementById('hud-item-ui').innerText = "";
            }

            // プレイヤーが3周を走りきって完走した瞬間、早期リターンを行ってこれ以降の描画を遮断
            if (player.lap > 3) {
                gameActive = false;
                
                // プレイヤーの総走行タイムを算出
                const playerTimeMs = Date.now() - raceStartTime;
                
                // 順位発表ボードを生成し表示
                showResults(playerRank, playerTimeMs);
                return; // 【最重要】直後の minimapCanvas 処理を実行させずに早期脱出
            }

            if (minimapCtx) {
                minimapCtx.clearRect(0, 0, 160, 160);

                minimapCtx.strokeStyle = 'rgba(30, 144, 255, 0.4)';
                minimapCtx.lineWidth = 4;
                minimapCtx.beginPath();
                
                const mapSegments = 60;
                for(let i=0; i<=mapSegments; i++) {
                    const p = raceCurve.getPointAt(i / mapSegments);
                    const mapX = 80 + p.x * 0.45;
                    const mapY = 80 + p.z * 0.45;
                    if(i===0) minimapCtx.moveTo(mapX, mapY);
                    else minimapCtx.lineTo(mapX, mapY);
                }
                minimapCtx.stroke();

                racers.forEach(r => {
                    const px = 80 + r.mesh.position.x * 0.45;
                    const py = 80 + r.mesh.position.z * 0.45;
                    
                    minimapCtx.fillStyle = r.isPlayer ? '#ff4757' : '#2ed573';
                    minimapCtx.beginPath();
                    minimapCtx.arc(px, py, r.isPlayer ? 5 : 3.5, 0, Math.PI * 2);
                    minimapCtx.fill();
                });
            }
        }

        // 公式風リザルト画面の生成と表示処理
        function showResults(playerRank, playerTimeMs) {
            const table = document.getElementById('result-table');
            if (!table) return;
            table.innerHTML = "";

            // 全員の成績テーブルを生成
            const standings = racers.map((r, idx) => ({
                id: idx,
                isPlayer: r.isPlayer,
                score: r.lap * 10 + r.progress,
                name: r.isPlayer ? "YOU (Player)" : racerNames[idx]
            }));
            // スコアが高い順にソート
            standings.sort((a, b) => b.score - a.score);

            standings.forEach((racerResult, index) => {
                const rankNum = index + 1;
                
                // タイム生成
                const rankOffset = rankNum - playerRank; 
                let simulatedTimeMs = playerTimeMs + rankOffset * (2500 + Math.random() * 1500);
                if (simulatedTimeMs < 12000) simulatedTimeMs = 12000;

                const mins = Math.floor(simulatedTimeMs / 60000);
                const secs = Math.floor((simulatedTimeMs % 60000) / 1000);
                const ms = Math.floor((simulatedTimeMs % 1000) / 10);
                const timeStr = `${mins}:${secs.toString().padStart(2, '0')}.${ms.toString().padStart(2, '0')}`;

                const row = document.createElement('tr');
                row.className = racerResult.isPlayer ? "result-row player-highlight" : "result-row";
                
                const suffixes = ["st", "nd", "rd", "th"];
                const rankText = rankNum <= 3 ? `${rankNum}${suffixes[rankNum - 1]}` : `${rankNum}th`;

                row.innerHTML = `
                    <td class="result-cell" style="font-size: 1.35rem; width: 15%;">${rankText}</td>
                    <td class="result-cell" style="width: 50%;">${racerResult.name}</td>
                    <td class="result-cell" style="width: 35%; text-align: right; font-family: monospace; font-size: 1.25rem;">${timeStr}</td>
                `;
                table.appendChild(row);
            });

            // リザルトステートに遷移
            setUIState(UI_STATES.RESULT);
        }

        // AI・プレイヤー用のアイテムスロットルーレット
        function triggerItemRoulette(racer) {
            if (racer.isItemRoulette) return;
            racer.isItemRoulette = true;
            
            const roulettePool = ["MUSHROOM", "STAR", "BANANA", "GREEN_SHELL", "RED_SHELL"];
            let counter = 0;
            const interval = setInterval(() => {
                const rand = roulettePool[Math.floor(Math.random() * roulettePool.length)];
                if (racer.isPlayer) {
                    // ルーレット中も巨大絵文字を高速シャッフルするように変更
                    document.getElementById('hud-item-ui').innerText = itemEmojiMap[rand];
                }
                counter++;
                if (counter > 8) {
                    clearInterval(interval);
                    racer.hasItem = rand;
                    if (racer.isPlayer) {
                        gameState.hasItem = rand;
                        // ルーレット決定後は巨大絵文字アイコンを適応
                        document.getElementById('hud-item-ui').innerText = itemEmojiMap[rand];
                        playSound('item_get');
                    }
                    racer.isItemRoulette = false;
                }
            }, 100);
        }

        function updateKartColor(hex) {
            gameState.kartColor = hex;
            if (chassisMesh && chassisMesh.material) {
                chassisMesh.material.color.set(hex);
            }
            if (underglowLight) {
                underglowLight.color.set(hex);
            }
        }

        // 前輪ピボットを配慮してタイヤグラフィックスを更新
        function updateWheelType(type) {
            gameState.wheelType = type;
            const newGeo = getWheelGeometry(type);
            
            if (leftWheel) {
                leftWheel.geometry.dispose();
                leftWheel.geometry = newGeo;
            }
            if (rightWheel) {
                rightWheel.geometry.dispose();
                rightWheel.geometry = newGeo;
            }
            if (backLeftWheel) {
                backLeftWheel.geometry.dispose();
                backLeftWheel.geometry = newGeo;
            }
            if (backRightWheel) {
                backRightWheel.geometry.dispose();
                backRightWheel.geometry = newGeo;
            }
        }

