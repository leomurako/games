                finishLineMesh = null;
            }

            racers.forEach(r => {
                if (!r.isPlayer && r.mesh) scene.remove(r.mesh);
            });
            racers = [];

            raceItems.forEach(item => { if (item.mesh) scene.remove(item.mesh); });
            raceItems = [];

            raceRamps.forEach(ramp => { if (ramp.mesh) scene.remove(ramp.mesh); });
            raceRamps = [];

            raceBananas.forEach(b => { if (b.mesh) scene.remove(b.mesh); });
            raceBananas = [];

