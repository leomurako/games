<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neon Kart 3D - Pop Edition</title>
    <!-- ポップで丸みのある日本語フォントの読み込み -->
    <link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght=700;900&family=Fredoka+One&display=swap" rel="stylesheet">
    <!-- Three.js CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        :root {
            --brand-primary: #ff4757; /* 明るい赤 */
            --brand-secondary: #ffa502; /* 明るい黄 */
            --brand-green: #2ed573; /* ルイージ風グリーン */
            --brand-blue: #1e90ff; /* 青空スカイブルー */
            --bg-bright: #faf5eb; /* 優しいクリームホワイト */
            --ui-border: #222222; /* くっきりした黒い縁 */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }

        body {
            font-family: 'Fredoka One', 'M PLUS Rounded 1c', sans-serif;
            background-color: #bae6fd; /* 明るい空色 */
            color: #222;
            overflow: hidden;
            width: 100vw;
            height: 100vh;
        }

        #bg-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        /* UIレイヤー */
        .ui-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 2;
            display: flex;
            flex-direction: column;
            pointer-events: none; /* ゲーム中にキャンバスの邪魔をしない */
        }

        /* ポップアート調（くっきり太いフチと影） */
        .pop-panel {
            background: var(--bg-bright);
            border: 4px solid var(--ui-border);
            border-radius: 20px;
            box-shadow: 6px 6px 0px var(--ui-border);
            pointer-events: auto; /* パネルの上は操作を許可 */
        }

        .screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex; 
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px;
            z-index: 5;
            pointer-events: auto; /* 画面上の入力を許可 */
        }

        /* 瞬時に「ぱっ」と切り替える設定 */
        .screen.hidden {
            display: none !important;
        }

        /* --- 1. メイン（ホーム）画面 --- */
        #home-screen {
            justify-content: space-between;
        }

        .brand-section {
            text-align: center;
            margin-top: 5vh;
            pointer-events: auto;
        }

        .game-title {
            font-size: 5rem;
            font-weight: 900;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: #ff4757;
            text-shadow: 4px 4px 0px #fff, 8px 8px 0px var(--ui-border);
            margin-bottom: 5px;
        }

        .game-subtitle {
            font-size: 1.2rem;
            font-weight: 900;
            letter-spacing: 4px;
            color: #1e90ff;
            text-shadow: 2px 2px 0px #fff;
            text-transform: uppercase;
        }

        .main-menu-buttons {
            display: flex;
            flex-direction: column;
            gap: 15px;
            width: 320px;
            margin-bottom: 8vh;
            pointer-events: auto;
        }

        /* ポップなボタンデザイン */
        .btn {
            font-family: inherit;
            font-size: 1.1rem;
            font-weight: 900;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 16px 30px;
            border-radius: 12px;
            border: 4px solid var(--ui-border);
            cursor: pointer;
            outline: none;
            box-shadow: 4px 4px 0px var(--ui-border);
            transition: transform 0.1s, box-shadow 0.1s;
            pointer-events: auto;
            text-align: center;
        }

        .btn-primary {
            background-color: var(--brand-secondary);
            color: #fff;
            text-shadow: 2px 2px 0px var(--ui-border);
        }
        .btn-primary:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--ui-border);
            background-color: #ffb923;
        }
        .btn-primary:active {
            transform: translate(2px, 2px);
            box-shadow: 2px 2px 0px var(--ui-border);
        }

        .btn-secondary {
            background-color: var(--brand-green);
            color: #fff;
            text-shadow: 2px 2px 0px var(--ui-border);
        }
        .btn-secondary:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--ui-border);
            background-color: #2ed573df;
        }
        .btn-secondary:active {
            transform: translate(2px, 2px);
            box-shadow: 2px 2px 0px var(--ui-border);
        }

        /* --- 2. スキンカスタマイズ画面 --- */
        #skin-screen {
            justify-content: flex-start;
            align-items: flex-start;
        }

        .screen-header {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            pointer-events: auto;
        }

        .screen-title {
            font-size: 2rem;
            font-weight: 900;
            letter-spacing: 1px;
            color: #222;
            background-color: #fff;
            padding: 8px 20px;
            border: 3px solid var(--ui-border);
            border-radius: 12px;
            box-shadow: 4px 4px 0px var(--ui-border);
        }

        .customize-panel {
            width: 380px;
            padding: 30px;
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .customize-section h3 {
            font-size: 1rem;
            text-transform: uppercase;
            color: #444;
            margin-bottom: 12px;
        }

        .color-selector {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 10px;
        }

        .color-dot {
            aspect-ratio: 1;
            border-radius: 10px;
            border: 3px solid var(--ui-border);
            cursor: pointer;
            box-shadow: 2px 2px 0px var(--ui-border);
            transition: all 0.2s;
        }
        .color-dot:hover {
            transform: scale(1.1);
        }
        .color-dot.active {
            border-color: #fff;
            box-shadow: 0 0 12px var(--selected-color), 2px 2px 0px var(--ui-border);
            transform: scale(1.05);
        }

        select.modern-select {
            width: 100%;
            padding: 12px;
            background: #fff;
            border: 3px solid var(--ui-border);
            border-radius: 8px;
            color: #222;
            font-family: inherit;
            font-weight: 900;
            font-size: 0.95rem;
            outline: none;
            cursor: pointer;
            box-shadow: 2px 2px 0px var(--ui-border);
        }

        .btn-back {
            padding: 10px 20px;
            font-size: 0.9rem;
        }

        /* --- 3. コース選択画面 --- */
        #course-screen {
            justify-content: space-between;
        }

        .course-grid {
            width: 100%;
            max-width: 1200px;
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 15px;
            margin: 20px 0;
            pointer-events: auto;
        }

        .course-card-modern {
            height: 180px;
            padding: 20px;
            background: #fff;
            border: 3px solid var(--ui-border);
            border-radius: 16px;
            box-shadow: 4px 4px 0px var(--ui-border);
            cursor: pointer;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: all 0.2s;
        }

        .course-card-modern:hover {
            background: #fffdf5;
            transform: translateY(-4px);
            box-shadow: 6px 6px 0px var(--ui-border);
        }

        .course-card-modern.active {
            background: #fff3cd;
            border-color: var(--brand-secondary);
            box-shadow: 6px 6px 0px var(--ui-border);
        }

        .course-card-modern h4 {
            font-size: 1.1rem;
            font-weight: 900;
            color: #222;
            margin-bottom: 5px;
        }

        .course-card-modern p {
            font-size: 0.8rem;
            color: #555;
            line-height: 1.4;
        }

        .course-difficulty {
            font-size: 0.8rem;
            color: var(--brand-primary);
            font-weight: 900;
        }

        .course-footer {
            width: 100%;
            max-width: 1200px;
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            pointer-events: auto;
        }

        /* --- 4. レース画面 --- */
        #game-screen {
            justify-content: space-between;
            padding: 30px;
            pointer-events: none; /* ゲーム中は基本操作を下に通す */
        }

        .hud-container {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            pointer-events: none;
        }

        .hud-group {
            display: flex;
            gap: 15px;
        }

        .hud-panel {
            background: #fff;
            border: 3px solid var(--ui-border);
            padding: 10px 20px;
            border-radius: 12px;
            box-shadow: 4px 4px 0px var(--ui-border);
            display: flex;
            flex-direction: column;
        }

        .hud-label {
            font-size: 0.8rem;
            text-transform: uppercase;
            font-weight: 900;
            color: #555;
        }

        .hud-value {
            font-size: 1.8rem;
            font-weight: 900;
            color: #222;
        }

        .hud-value-accent {
            color: var(--brand-primary);
        }

        /* アイテムボックスのサイズ */
        .hud-item-box {
            width: 75px;
            height: 75px;
            background: #fff;
            border: 4px solid var(--ui-border);
            border-radius: 16px;
            box-shadow: 4px 4px 0px var(--ui-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.6rem; /* 巨大な絵文字向けに調整 */
            font-weight: 900;
            color: var(--brand-primary);
            text-align: center;
            line-height: 1;
        }

        .minimap-panel {
            width: 160px;
            height: 160px;
            background: #fff;
            border: 3px solid var(--ui-border);
            border-radius: 16px;
            box-shadow: 4px 4px 0px var(--ui-border);
            position: relative;
            overflow: hidden;
        }

        #minimap-canvas {
            width: 100%;
            height: 100%;
        }

        /* 順位パネルの右下移動に伴い、操作ヘルプを画面左下に綺麗に避けて配置 */
        .game-controls-help {
            position: absolute;
            bottom: 30px;
            left: 200px; /* Abort Race ボタンから右側にオフセット */
            background: rgba(255, 255, 255, 0.95);
            padding: 15px;
            border-radius: 12px;
            border: 3px solid var(--ui-border);
            box-shadow: 4px 4px 0px var(--ui-border);
            font-size: 0.8rem;
            line-height: 1.6;
            color: #222;
            pointer-events: none;
            z-index: 10;
        }

        .game-controls-help span {
            color: var(--brand-primary);
            font-weight: 900;
        }

        .btn-exit {
            pointer-events: auto; /* このボタンだけはクリックを許可 */
            position: absolute;
            bottom: 30px;
            left: 30px;
            font-size: 0.85rem;
            padding: 12px 20px;
            z-index: 10;
        }

        /* 右下にたたずむ巨大順位パネル */
        #hud-rank-panel {
            position: absolute;
            bottom: 30px;
            right: 30px;
            background: #fff;
            border: 4px solid var(--ui-border);
            padding: 10px 25px;
            border-radius: 20px;
            box-shadow: 6px 6px 0px var(--ui-border);
            display: flex;
            flex-direction: column;
            align-items: center;
            pointer-events: none;
            z-index: 10;
        }
        .hud-rank-value {
            font-size: 4rem;
            font-weight: 900;
            color: var(--brand-primary);
            text-shadow: 2px 2px 0px #fff, 4px 4px 0px var(--ui-border);
            line-height: 1.1;
        }

        #action-toast {
            position: absolute;
            top: 25%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.5);
            font-size: 2.8rem;
            font-weight: 900;
            font-style: italic;
            color: #ffcc00;
            text-shadow: 3px 3px 0px #fff, 6px 6px 0px var(--ui-border);
            opacity: 0;
            transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            pointer-events: none;
            z-index: 10;
        }
        #action-toast.active {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1.1);
        }

        #screen-filter {
            position: absolute;
            top:0; left:0; width:100%; height:100%;
            pointer-events: none;
            z-index: 4;
            transition: background 0.3s ease;
        }

        /* --- 5. リザルト（結果発表）画面用スタイル --- */
        .result-panel {
            width: 100%;
            max-width: 600px;
            padding: 20px;
            margin: 20px 0;
            max-height: 60vh;
            overflow-y: auto;
            pointer-events: auto;
        }

        .result-panel::-webkit-scrollbar {
            width: 10px;
        }
        .result-panel::-webkit-scrollbar-track {
            background: #faf5eb;
            border-left: 3px solid var(--ui-border);
            border-radius: 0 16px 16px 0;
        }
        .result-panel::-webkit-scrollbar-thumb {
            background: var(--ui-border);
            border-radius: 5px;
        }

        .result-table {
            width: 100%;
            border-collapse: collapse;
            font-weight: 900;
            font-size: 1.15rem;
        }

        .result-row {
            border-bottom: 3px solid var(--ui-border);
        }
        .result-row:last-child {
            border-bottom: none;
        }

        .result-row.player-highlight {
            background-color: #ffeaa7;
            color: #ff4757;
            text-shadow: 1px 1px 0px #fff;
        }

        .result-cell {
            padding: 12px 15px;
        }
    </style>
</head>
<body>

    <canvas id="bg-canvas"></canvas>
    <div id="screen-filter"></div>

    <div class="ui-container">

        <div id="action-toast">JUMP ACTION!</div>

        <!-- 1. メイン（ホーム）画面 -->
        <div id="home-screen" class="screen">
            <div class="brand-section">
                <h1 class="game-title">Neon Kart 3D</h1>
                <p class="game-subtitle">Pop & Friendly Racing</p>
            </div>

            <div class="main-menu-buttons">
                <button class="btn btn-primary" id="home-start-btn">Race Start</button>
                <button class="btn btn-secondary" id="home-customize-btn">Customize Kart</button>
                <!-- ホーム画面用の操作説明ボタン -->
                <button class="btn btn-secondary" id="home-help-btn" style="background-color: var(--brand-blue); text-shadow: 2px 2px 0px var(--ui-border);">How to Play</button>
            </div>
        </div>

        <!-- 2. スキンカスタマイズ画面 -->
        <div id="skin-screen" class="screen hidden">
            <div class="screen-header">
                <h2 class="screen-title">Customize Kart</h2>
                <button class="btn btn-secondary btn-back" id="skin-back-btn">Back to Menu</button>
            </div>

            <div class="pop-panel customize-panel">
                <div class="customize-section">
                    <h3>Body Color</h3>
                    <div class="color-selector" id="color-selector"></div>
                </div>

                <div class="customize-section">
                    <h3>Wheel Type</h3>
                    <select id="wheel-select" class="modern-select">
                        <option value="standard">STANDARD SLICK</option>
                        <option value="slick">LOW PROFILE SPORT</option>
                        <option value="offroad">CYBER OFF-ROAD</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- 3. コース選択画面 -->
        <div id="course-screen" class="screen hidden">
            <div class="screen-header">
                <h2 class="screen-title">Select Circuit</h2>
            </div>

            <div class="course-grid" id="course-grid"></div>

            <div class="course-footer">
                <button class="btn btn-secondary btn-back" id="course-back-btn">Back</button>
                <button class="btn btn-primary" id="course-launch-btn">Launch Race</button>
            </div>
        </div>

        <!-- 4. レース画面 -->
        <div id="game-screen" class="screen hidden">
            <!-- 【不具合修正】カウントダウン表示用のポップなテキスト表示エリアを追加 -->
            <div id="countdown-overlay" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 8rem; font-weight: 900; text-shadow: 4px 4px 0px #fff, 8px 8px 0px var(--ui-border); z-index: 100; pointer-events: none; font-family: 'Fredoka One', 'M PLUS Rounded 1c', sans-serif;"></div>

            <div class="hud-container">
                <div class="hud-group">
                    <div class="hud-panel">
                        <span class="hud-label">Lap</span>
                        <span class="hud-value" id="hud-lap">1/3</span>
                    </div>
                    <!-- 中身がない時は空になるアイテムボックス -->
                    <div class="hud-item-box" id="hud-item-ui"></div>
                </div>

                <div class="minimap-panel">
                    <canvas id="minimap-canvas"></canvas>
                </div>
            </div>

            <!-- 右下にたたずむ巨大順位パネル -->
            <div id="hud-rank-panel">
                <span class="hud-label" style="font-size: 0.95rem; letter-spacing: 1px;">POSITION</span>
                <span class="hud-rank-value" id="hud-rank">12th</span>
            </div>

            <button class="btn btn-secondary btn-exit" id="game-exit-btn">Abort Race</button>
        </div>

        <!-- 5. リザルト（結果発表）画面 -->
        <div id="result-screen" class="screen hidden">
            <div class="brand-section" style="margin-top: 2vh;">
                <h1 class="game-title" style="font-size: 4rem; text-shadow: 3px 3px 0px #fff, 6px 6px 0px var(--ui-border); color: var(--brand-secondary);">Race Results</h1>
                <p class="game-subtitle" style="color: var(--brand-green);">Final Standings</p>
            </div>

            <div class="pop-panel result-panel">
                <table class="result-table" id="result-table">
                    <!-- JSにより順位行が自動生成されます -->
                </table>
            </div>

            <div style="display: flex; gap: 20px; pointer-events: auto; margin-bottom: 3vh;">
                <button class="btn btn-secondary" id="result-retry-btn">Retry Race</button>
                <button class="btn btn-primary" id="result-menu-btn">Back to Menu</button>
            </div>
        </div>

        <!-- 6. 操作方法ポップアップ（モーダル） -->
        <div id="help-modal" class="screen hidden" style="background: rgba(186, 230, 253, 0.95); z-index: 20; pointer-events: auto;">
            <div class="screen-header" style="justify-content: center; margin-bottom: 30px;">
                <h2 class="screen-title">How to Play</h2>
            </div>
            
            <div class="pop-panel" style="width: 100%; max-width: 500px; padding: 30px; background: #fff; font-size: 1.1rem; line-height: 2.2;">
                <div style="margin-bottom: 25px; font-weight: 900; color: #222;">
                    <span style="color: var(--brand-primary);">[W] / [↑]</span> Accelerator (アクセル)<br>
                    <span style="color: var(--brand-primary);">[S] / [↓]</span> Brake / Reverse (ブレーキ/後退)<br>
                    <span style="color: var(--brand-primary);">[A/D] / [←/→]</span> Steering (旋回)<br>
                    <span style="color: var(--brand-primary);">[Space]</span> Hold: Drift (ドリフト) / Tap: Jump Action (ジャンプアクション)<br>
                    <span style="color: var(--brand-primary);">[Q] / [E]</span> Use Item (アイテム使用)<br>
                    <span style="color: var(--brand-primary);">[C] / [R]</span> Back View Mirror (バックミラー表示)
                </div>
                <button class="btn btn-primary" id="help-close-btn" style="width: 100%;">Close</button>
            </div>
        </div>

    </div>

    <script>
        // ========================================================
        // 1. グローバル定数・状態管理（TDZエラーを防ぐため最上部で一括定義）
        // ========================================================
        const UI_STATES = {
            MAIN: 'main',
            SKIN: 'skin',
            COURSE: 'course',
            GAME: 'game',
            RESULT: 'result',
            HELP: 'help' 
        };

        const ROAD_WIDTH = 22.0; // 全コースにおいて道幅を大きく（12.0 -> 22.0）

        const colorsList = [
            { name: "Red", hex: "#ff4757" },
            { name: "Orange", hex: "#ff7f50" },
            { name: "Gold", hex: "#ffa502" },
            { name: "Green", hex: "#2ed573" },
            { name: "Blue", hex: "#1e90ff" },
            { name: "Pink", hex: "#ff6b81" }
        ];

        // 公式風キャラクターリスト (12名のメンバー構成)
        const racerNames = [
            "YOU (Player)",
            "Mario",
            "Luigi",
            "Peach",
            "Yoshi",
            "Toad",
            "Bowser",
            "Donkey Kong",
            "Wario",
            "Waluigi",
            "Daisy",
            "Koopa Troopa"
        ];

        // 文字ではなくビジュアル（巨大絵文字）で表現するためのマップ
        const itemEmojiMap = {
            "MUSHROOM": "🍄",
            "STAR": "⭐",
            "BANANA": "🍌",
            "GREEN_SHELL": "🐢",
            "RED_SHELL": "🎯"
        };

        const courses = [
            { name: "1. Mario Circuit", diff: "EASY", color: 0x2ed573, desc: "青空のもとを走る、芝生に囲まれた基本サーキット。" },
            { name: "2. Desert Ruins", diff: "NORMAL", color: 0xffa502, desc: "起伏（コブ）が激しく、細かな丘陵が続く砂漠ステージ。" },
            { name: "3. Peach Garden", diff: "NORMAL", color: 0xff6b81, desc: "美しい花に囲まれた、タイトなコーナーが続く中速サーキット。" },
            { name: "4. DK Summit", diff: "HARD", color: 0x2bcbba, desc: "大ジャンプ台と急峻な高低差が待ち受ける雪山スロープ。" },
