                    Math.random() * 0.1,
                    (Math.random() - 0.5) * 0.15
                )
            });
        }

        function updateDriftSparks() {
            if (!scene) return;
            for (let i = driftSparks.length - 1; i >= 0; i--) {
                const spark = driftSparks[i];
                spark.age++;
                spark.mesh.position.add(spark.velocity);
                const scale = Math.max(0.01, 1.0 - (spark.age / spark.maxAge));
                spark.mesh.scale.set(scale, scale, scale);
                
                if (spark.age >= spark.maxAge) {
                    scene.remove(spark.mesh);
                    spark.mesh.geometry.dispose();
                    spark.mesh.material.dispose();
                    driftSparks.splice(i, 1);
                }
            }
        }

