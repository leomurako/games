        // パーティクルを丸みのあるポップな形状にするためのキャンバステクスチャ作成
        function createParticleTexture(theme) {
            const canvas = document.createElement('canvas');
            canvas.width = 32;
            canvas.height = 32;
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = '#ffffff';

            if (theme === 'sakura') {
                ctx.beginPath();
                ctx.ellipse(16, 16, 13, 7, Math.PI / 4, 0, Math.PI * 2);
                ctx.fill();
                ctx.fillStyle = 'rgba(0,0,0,0)';
                ctx.globalCompositeOperation = 'destination-out';
                ctx.beginPath();
                ctx.arc(28, 28, 5, 0, Math.PI * 2);
                ctx.fill();
            } else if (theme === 'autumn') {
                ctx.beginPath();
                ctx.ellipse(16, 16, 12, 6, -Math.PI / 6, 0, Math.PI * 2);
                ctx.fill();
            } else if (theme === 'grass') {
                ctx.beginPath();
                ctx.ellipse(16, 16, 11, 5, Math.PI / 3, 0, Math.PI * 2);
                ctx.fill();
            } else if (theme === 'water') {
                ctx.strokeStyle = '#ffffff';
                ctx.lineWidth = 2.0;
                ctx.beginPath();
                ctx.arc(16, 16, 11, 0, Math.PI * 2);
                ctx.stroke();
                ctx.fillStyle = '#ffffff';
                ctx.beginPath();
                ctx.arc(11, 11, 2.5, 0, Math.PI * 2);
                ctx.fill();
            } else {
                const grad = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);
                grad.addColorStop(0, 'rgba(255,255,255,1)');
                grad.addColorStop(0.3, 'rgba(255,255,255,0.8)');
                grad.addColorStop(1, 'rgba(255,255,255,0)');
                ctx.fillStyle = grad;
                ctx.fillRect(0, 0, 32, 32);
            }

            const texture = new THREE.CanvasTexture(canvas);
            texture.needsUpdate = true;
            return texture;
        }

        // コースに合わせた環境天気（降雪・桜吹雪・砂嵐など）を生成する処理
        function initWeatherParticles(theme) {
            if (weatherParticles) {
                scene.remove(weatherParticles);
                weatherParticles.geometry.dispose();
                weatherParticles.material.dispose();
                weatherParticles = null;
            }

            const particleCount = 200;
            const geo = new THREE.BufferGeometry();
            const positions = new Float32Array(particleCount * 3);
            const velocities = [];

            for (let i = 0; i < particleCount; i++) {
                positions[i * 3] = (Math.random() - 0.5) * 200;
                positions[i * 3 + 1] = Math.random() * 45 + 1;
                positions[i * 3 + 2] = (Math.random() - 0.5) * 200;

                let vy = -0.05 - Math.random() * 0.08;
                let vx = (Math.random() - 0.5) * 0.04;
                let vz = (Math.random() - 0.5) * 0.04;

                if (theme === 'desert') {
                    vy = -0.01 - Math.random() * 0.02;
                    vx = -0.18 - Math.random() * 0.15;
                } else if (theme === 'water') {
                    vy = 0.05 + Math.random() * 0.06;
                } else if (theme === 'dark') {
                    vy = -0.02 - Math.random() * 0.03;
                } else if (theme === 'sakura' || theme === 'autumn') {
                    vy = -0.03 - Math.random() * 0.04;
                    vx = (Math.random() - 0.5) * 0.08;
                }

                velocities.push(new THREE.Vector3(vx, vy, vz));
            }

            geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));

            let pColor = 0xffffff;
            let pSize = 0.5;

            if (theme === 'sakura') {
                pColor = 0xffb7c5; 
                pSize = 0.65;
            } else if (theme === 'desert') {
                pColor = 0xdfb15b; 
                pSize = 0.45;
            } else if (theme === 'ice') {
                pColor = 0xffffff; 
                pSize = 0.55;
            } else if (theme === 'dark') {
                pColor = 0xff4757; 
                pSize = 0.4;
            } else if (theme === 'cosmic') {
                pColor = 0xe879f9; 
                pSize = 0.5;
            } else if (theme === 'water') {
                pColor = 0xbae6fd; 
                pSize = 0.45;
            } else if (theme === 'autumn') {
                pColor = 0xf97316; 
                pSize = 0.6;
            } else {
                pColor = 0x4ade80; 
                pSize = 0.4;
            }

            const pTex = createParticleTexture(theme);
            const mat = new THREE.PointsMaterial({
                color: pColor,
                size: pSize,
                map: pTex,
                transparent: true,
                opacity: 0.85,
                depthWrite: false,
                blending: THREE.AdditiveBlending
            });

            weatherParticles = new THREE.Points(geo, mat);
            weatherParticles.velocities = velocities;
            scene.add(weatherParticles);
        }

        // 毎フレーム、プレイヤーのいる場所にパーティクルが追従して移動する処理
        function updateWeatherParticles() {
            if (!weatherParticles || !camera) return;
            
            const positions = weatherParticles.geometry.attributes.position.array;
            const velocities = weatherParticles.velocities;
            const camPos = camera.position;

            for (let i = 0; i < velocities.length; i++) {
                let px = positions[i * 3];
                let py = positions[i * 3 + 1];
                let pz = positions[i * 3 + 2];
                const v = velocities[i];

                px += v.x;
                py += v.y;
                pz += v.z;

                if (Math.abs(px - camPos.x) > 110) {
                    px = camPos.x + (Math.random() - 0.5) * 180;
                }
                if (py < 0 || py > 45) {
                    py = 35 + Math.random() * 10;
                }
                if (Math.abs(pz - camPos.z) > 110) {
                    pz = camPos.z + (Math.random() - 0.5) * 180;
                }

                positions[i * 3] = px;
                positions[i * 3 + 1] = py;
                positions[i * 3 + 2] = pz;
            }
            weatherParticles.geometry.attributes.position.needsUpdate = true;
        }

        // ========================================================
        // 4. サウンド・シンセ処理
        // ========================================================
        function initAudio() {
            if (audioCtx) return;
            try {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                
                engineOsc = audioCtx.createOscillator();
                engineFilter = audioCtx.createBiquadFilter();
                const engineGain = audioCtx.createGain();

                engineOsc.type = 'sawtooth';
                engineOsc.frequency.setValueAtTime(40, audioCtx.currentTime);

                engineFilter.type = 'lowpass';
                engineFilter.frequency.setValueAtTime(150, audioCtx.currentTime);

                engineGain.gain.setValueAtTime(0.04, audioCtx.currentTime); 

                engineOsc.connect(engineFilter);
                engineFilter.connect(engineGain);
                engineGain.connect(audioCtx.destination);
                engineOsc.start();
            } catch (e) {
                console.warn("Audio initialization failed:", e);
            }
        }

        function playSound(type) {
            if (!audioCtx) return;
            try {
                if (audioCtx.state === 'suspended') audioCtx.resume();
                
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.connect(gain);
                gain.connect(audioCtx.destination);

                if (type === 'boost') {
                    osc.type = 'sawtooth';
                    osc.frequency.setValueAtTime(250, audioCtx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(1200, audioCtx.currentTime + 0.5);
                    gain.gain.setValueAtTime(0.08, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.5);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.5);
                } else if (type === 'hit') {
                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(120, audioCtx.currentTime);
                    osc.frequency.linearRampToValueAtTime(20, audioCtx.currentTime + 0.4);
                    gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.4);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.4);
                } else if (type === 'item_get') {
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(587.33, audioCtx.currentTime); 
                    osc.frequency.setValueAtTime(880, audioCtx.currentTime + 0.08); 
                    osc.frequency.setValueAtTime(1174.66, audioCtx.currentTime + 0.16); 
                    gain.gain.setValueAtTime(0.06, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.3);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.3);
                } else if (type === 'trick') {
                    osc.type = 'square';
                    osc.frequency.setValueAtTime(440, audioCtx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(1800, audioCtx.currentTime + 0.25);
                    gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.25);
