        // ========================================================
        // 10. AI & コース物理
        // ========================================================
        function getAIOvertakeOffset(racer, trackLength) {
            let avoidOffset = 0;
            let closestAhead = null;
            let closestAheadDist = 35.0; 

            racers.forEach(other => {
                if (other === racer) return;
                let dp = other.progress - racer.progress;
                if (dp < 0) dp += 1.0; 
                const dist = dp * trackLength;
                if (dist > 0.1 && dist < closestAheadDist) {
                    closestAheadDist = dist;
                    closestAhead = other;
                }
            });

            if (closestAhead && closestAheadDist < 20.0) {
                const latDiff = racer.lateralOffset - closestAhead.lateralOffset;
                if (Math.abs(latDiff) < 1.8) {
                    const dodgeDir = latDiff >= 0 ? 1.0 : -1.0;
                    avoidOffset = dodgeDir * 2.3; 
                }
            }

            raceBananas.forEach(banana => {
                const distToBanana = (banana.ratio - racer.progress + 1.0) % 1.0;
                if (distToBanana > 0 && distToBanana < 0.08) {
                    const latDiff = Math.abs(racer.lateralOffset - banana.offset);
                    if (latDiff < 2.2) {
                        avoidOffset = racer.lateralOffset > banana.offset ? 2.5 : -2.5;
                    }
                }
            });

            return avoidOffset;
        }

