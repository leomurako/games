        // ========================================================
        // 8. サポート・各種ヘルパー関数
        // ========================================================
        function createPopItemMesh(text, isBillboard, backgroundColor, size) {
            const canvas = document.createElement('canvas');
            const isLongText = text.length > 3;
            canvas.width = isLongText ? 512 : 128;
            canvas.height = 128;
            const ctx = canvas.getContext('2d');

            ctx.fillStyle = backgroundColor || '#ffffff';
            ctx.strokeStyle = '#222222';
            ctx.lineWidth = 8;

            if (isLongText) {
                ctx.beginPath();
                if (ctx.roundRect) {
                    ctx.roundRect(10, 10, 492, 108, 24);
                } else {
                    ctx.rect(10, 10, 492, 108);
                }
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = '#222222';
                ctx.font = 'bold 36px "M PLUS Rounded 1c", sans-serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(text, 256, 64);
            } else {
                ctx.beginPath();
                ctx.arc(64, 64, 55, 0, Math.PI * 2);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = '#222222';
                ctx.font = 'bold 64px "M PLUS Rounded 1c", sans-serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(text, 64, 64);
            }

            const texture = new THREE.CanvasTexture(canvas);
            const mat = new THREE.MeshBasicMaterial({ map: texture, transparent: true, side: THREE.DoubleSide });
            
            const width = size || 2.0;
            const height = isLongText ? width * 0.25 : width;
            const geo = new THREE.PlaneGeometry(width, height);
            const mesh = new THREE.Mesh(geo, mat);
            return mesh;
        }

        function createVisualLightningBolt(position) {
            if (!scene) return;
            const group = new THREE.Group();
            const material = new THREE.MeshBasicMaterial({ color: 0xffea00 });
            
            let curPos = position.clone();
            curPos.y += 0.2;
            for (let i = 0; i < 5; i++) {
                const height = 4.0;
                const geo = new THREE.CylinderGeometry(0.15, 0.15, height, 5);
                const mesh = new THREE.Mesh(geo, material);
                
                const offset = new THREE.Vector3(
                    (Math.random() - 0.5) * 1.5,
                    height / 2,
                    (Math.random() - 0.5) * 1.5
                );
                mesh.position.copy(curPos).add(offset);
                mesh.lookAt(curPos.clone().add(new THREE.Vector3(offset.x * 2, height, offset.z * 2)));
                group.add(mesh);
                
                curPos.add(new THREE.Vector3(offset.x * 2, height, offset.z * 2));
            }
            scene.add(group);
            
            setTimeout(() => {
                scene.remove(group);
                group.traverse(child => {
                    if (child.geometry) child.geometry.dispose();
                    if (child.material) child.material.dispose();
                });
            }, 200);
        }

        function getRacerRank(racer) {
            if (racers.length === 0) return 12;
            const rankList = racers.map((r, idx) => ({
                racer: r,
                score: r.lap * 10 + r.progress
            }));
            rankList.sort((a, b) => b.score - a.score);
            const rankIndex = rankList.findIndex(item => item.racer === racer);
            return rankIndex !== -1 ? rankIndex + 1 : 12;
        }

        function getRankBasedItem(rank) {
            if (rank === 1) {
                const pool = ["BANANA", "BANANA", "GREEN_SHELL", "GREEN_SHELL", "MUSHROOM"];
                return pool[Math.floor(Math.random() * pool.length)];
            } else if (rank <= 3) {
                const pool = ["GREEN_SHELL", "RED_SHELL", "MUSHROOM", "TRIPLE_BANANA", "TRIPLE_MUSHROOM"];
                return pool[Math.floor(Math.random() * pool.length)];
            } else if (rank <= 6) {
                const pool = ["RED_SHELL", "TRIPLE_GREEN_SHELL", "MUSHROOM", "TRIPLE_MUSHROOM", "GOLDEN_MUSHROOM"];
                return pool[Math.floor(Math.random() * pool.length)];
            } else if (rank <= 9) {
                const pool = ["TRIPLE_MUSHROOM", "STAR", "GOLDEN_MUSHROOM"];
                if (raceBlueShellCount < 1) pool.push("BLUE_SHELL");
                if (raceLightningCount < 1) pool.push("LIGHTNING");
                
                const item = pool[Math.floor(Math.random() * pool.length)];
                if (item === "LIGHTNING") raceLightningCount++;
                if (item === "BLUE_SHELL") raceBlueShellCount++;
                return item;
            } else {
                const pool = ["STAR", "GOLDEN_MUSHROOM", "TRIPLE_MUSHROOM"];
                if (raceLightningCount < 2) pool.push("LIGHTNING");
                if (raceBlueShellCount < 2) pool.push("BLUE_SHELL");
                
                const item = pool[Math.floor(Math.random() * pool.length)];
                if (item === "LIGHTNING") raceLightningCount++;
                if (item === "BLUE_SHELL") raceBlueShellCount++;
                return item;
            }
        }

        // ========================================================
        // 9. アイテム処理 & コレクタブル更新
        // ========================================================
        function executeItemUse(racer, itemType) {
            let activeType = itemType;
            if (itemType === "TRIPLE_MUSHROOM") activeType = "MUSHROOM";
            else if (itemType === "TRIPLE_BANANA") activeType = "BANANA";
            else if (itemType === "TRIPLE_GREEN_SHELL") activeType = "GREEN_SHELL";

            if (activeType === "MUSHROOM") {
                racer.boostTimer = 120;
                if (racer.isPlayer) { 
                    playSound('boost');
                    triggerBoostVisualEffect();
                }
            } else if (activeType === "STAR") {
                racer.starTimer = 300; 
                racer.boostTimer = 300;
                if (racer.isPlayer) { 
                    playSound('boost');
                    document.getElementById('screen-filter').style.background = 'rgba(255, 255, 255, 0.2)';
                    setTimeout(() => { document.getElementById('screen-filter').style.background = 'none'; }, 1000);
                }
            } else if (activeType === "GOLDEN_MUSHROOM") {
                racer.goldenTimer = 300; 
                racer.boostTimer = 120;
                if (racer.isPlayer) { 
                    playSound('boost');
                    triggerBoostVisualEffect();
                }
            } else if (activeType === "BANANA") {
                const trackLength = raceCurve.getLength();
                const offsetProgress = 3.5 / trackLength; 
                let targetProgress = racer.progress - offsetProgress;
                if (targetProgress < 0) targetProgress += 1.0;

                const posAtTarget = raceCurve.getPointAt(targetProgress % 1.0);
                const tangentAtTarget = raceCurve.getTangentAt(targetProgress % 1.0).normalize();
                const rightAtTarget = new THREE.Vector3().crossVectors(tangentAtTarget, new THREE.Vector3(0, 1, 0)).normalize();

                const finalBananaPos = posAtTarget.clone()
                    .add(rightAtTarget.clone().multiplyScalar(racer.lateralOffset))
                    .add(new THREE.Vector3(0, 0.5, 0));

                const bananaMesh = createPopItemMesh("🍌", false, '#ffffff', 1.5);
                bananaMesh.position.copy(finalBananaPos);
                scene.add(bananaMesh);

                raceBananas.push({
                    mesh: bananaMesh,
                    pos: finalBananaPos,
                    ratio: targetProgress % 1.0,
                    offset: racer.lateralOffset,
                    age: 0,
                    maxAge: 1200 
                });
            } else if (activeType === "GREEN_SHELL") {
                fireProjectile("green", racer);
            } else if (activeType === "RED_SHELL") {
                fireProjectile("red", racer);
            } else if (activeType === "BLUE_SHELL") {
                fireBlueShell(racer);
            } else if (activeType === "LIGHTNING") {
                triggerLightning(racer);
            }

            if (itemType.startsWith("TRIPLE_")) {
                racer.itemCount--;
                if (racer.itemCount > 0) {
                    racer.hasItem = itemType;
                    if (racer.isPlayer) {
                        gameState.hasItem = itemType;
                        document.getElementById('hud-item-ui').innerText = itemEmojiMap[itemType].replace("x3", `x${racer.itemCount}`);
                    }
                    return; 
                }
            }

            if (itemType === "GOLDEN_MUSHROOM" && racer.goldenTimer > 0) {
                racer.hasItem = "GOLDEN_MUSHROOM";
                if (racer.isPlayer) {
                    gameState.hasItem = "GOLDEN_MUSHROOM";
                }
                return;
            }

            racer.hasItem = null;
            if (racer.isPlayer) {
                gameState.hasItem = null;
                document.getElementById('hud-item-ui').innerText = "";
            }
        }

        function usePlayerItem() {
            if (!gameState.hasItem || gameState.isItemRoulette) return;
            executeItemUse(racers[0], gameState.hasItem);
        }

        function fireProjectile(type, owner) {
            if (!raceCurve) return;
            
            let emoji = "🐢";
            if (type === "red") emoji = "🎯";

            const pMesh = createPopItemMesh(emoji, false, '#ffffff', 2.0);
            pMesh.position.copy(owner.mesh.position);
            scene.add(pMesh);

            let target = null;
            if (type === "red") {
                let closestAheadDist = 9999;
                racers.forEach(other => {
                    if (other === owner) return;
                    let dp = other.progress - owner.progress;
                    if (dp < 0) dp += 1.0; 
                    if (dp > 0 && dp < closestAheadDist) {
                        closestAheadDist = dp;
                        target = other;
                    }
                });
            }

            raceProjectiles.push({
                mesh: pMesh,
                progress: owner.progress + 0.005,
                lateralOffset: owner.lateralOffset,
                type: type,
                owner: owner,
                target: target,
                speed: 0.6, 
                active: true
            });
            if (owner.isPlayer) playSound('boost'); 
        }

        function fireBlueShell(owner) {
            if (!raceCurve) return;
            const rankList = racers.map((r, idx) => ({ id: idx, score: r.lap * 10 + r.progress, racer: r }));
            rankList.sort((a,b) => b.score - a.score);
            const target = rankList[0].racer; 

