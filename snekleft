        function createCrashParticles(x, y, z) {
            const count = 18;
            const pGeo = new THREE.BoxGeometry(0.1, 0.1, 0.1);
            for (let i = 0; i < count; i++) {
                const mat = materials.snekHead.clone();
                const mesh = new THREE.Mesh(pGeo, mat);
                mesh.position.set(x, y, z);
                mesh.castShadow = true;
                scene.add(mesh);

                const velocity = new THREE.Vector3(
                    (Math.random() - 0.5) * 0.16,
                    Math.random() * 0.16 + 0.05,
                    (Math.random() - 0.5) * 0.16
                );

                particles.push({
                    mesh: mesh,
                    velocity: velocity,
                    life: 1.0,
                    decay: Math.random() * 0.03 + 0.02
                });
            }
        }

        function updateParticles() {
            for (let i = particles.length - 1; i >= 0; i--) {
                const p = particles[i];
                p.mesh.position.add(p.velocity);
                p.velocity.y -= 0.007;

                p.mesh.rotation.x += 0.15;
                p.mesh.rotation.y += 0.15;

                p.life -= p.decay;
                p.mesh.scale.set(p.life, p.life, p.life);

                if (p.life <= 0) {
                    scene.remove(p.mesh);
                    p.mesh.geometry.dispose();
                    p.mesh.material.dispose();
                    particles.splice(i, 1);
                }
            }
        }

        // --- アニメーション ＆ ループ ---
        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);

            const time = clock.getElapsedTime();

            spectatorMeshes.forEach(spec => {
                spec.position.y = spec.userData.offsetY + Math.sin(time * spec.userData.speed + spec.userData.phase) * 0.04;
            });

            updateParticles();

            if (gameState === STATE_PLAYING && !gamePaused) {
                if (isPressed) {
                    snek.angle += snek.turnSpeed; 
                } else {
                    snek.angle -= snek.turnSpeed; 
                }

                const dx = Math.cos(snek.angle) * snek.speed;
                const dz = -Math.sin(snek.angle) * snek.speed;

                snek.x += dx;
                snek.z += dz;

                snek.headGroup.position.set(snek.x, snek.y, snek.z);
                snek.headGroup.rotation.y = snek.angle;

                const distFromLast = Math.hypot(snek.x - lastSegmentPos.x, snek.z - lastSegmentPos.z);
                if (distFromLast >= 0.19) {
                    spawnBodySegment({ x: snek.x, z: snek.z });
                    lastSegmentPos = { x: snek.x, z: snek.z };
                }

                if (currentLevelIndex === 0) {
                    updateLevel1Assist();
                } else {
                    clearLevel1Assist();
                }

                checkCollisions();

            } else if (gameState === STATE_FALLING) {
                clearLevel1Assist();

                snek.y -= 0.12;
                snek.headGroup.position.y = snek.y;
                snek.bodySegments.forEach(seg => {
                    seg.position.y -= 0.12;
                });

                crashTimer++;
                if (crashTimer === 15) { 
                    triggerGameOver();
                }
            } else if (gameState === STATE_CRASHED) {
                clearLevel1Assist();

                crashTimer++;
                if (crashTimer === 15) { 
                    triggerGameOver();
                }
            }

            renderer.render(scene, camera);
        }

        function checkOnPlatformWithGrace(x, z) {
            const gx = Math.floor(x);
            const gz = Math.floor(z);

            if (gz < 0 || gz >= mapData.length || gx < 0 || gx >= mapData[0].length) {
                return false;
            }

            if (mapData[gz][gx] !== 0) {
                return true;
            }

            const graceMargin = 0.22; 
            const adjacentOffsets = [
                {dx: -1, dz: 0}, {dx: 1, dz: 0}, {dx: 0, dz: -1}, {dx: 0, dz: 1},
                {dx: -1, dz: -1}, {dx: 1, dz: -1}, {dx: -1, dz: 1}, {dx: 1, dz: 1}
            ];

            for (const offset of adjacentOffsets) {
                const nx = gx + offset.dx;
                const nz = gz + offset.dz;

                if (nz >= 0 && nz < mapData.length && nx >= 0 && nx < mapData[0].length) {
                    if (mapData[nz][nx] !== 0) {
                        const safeCenterX = nx + 0.5;
                        const safeCenterZ = nz + 0.5;
                        const distToSafeCenter = Math.hypot(x - safeCenterX, z - safeCenterZ);

                        if (distToSafeCenter < (0.5 + graceMargin)) {
                            return true;
                        }
                    }
                }
            }

            return false;
        }

        // 手すり（柵）との当たり判定
        function checkRailingCollision() {
            const gx = Math.floor(snek.x);
            const gz = Math.floor(snek.z);

            if (gz < 0 || gz >= mapData.length || gx < 0 || gx >= mapData[0].length) return false;

            const tileLeft = gx;
            const tileRight = gx + 1.0;
            const tileTop = gz;
            const tileBottom = gz + 1.0;

            const snekRadius = 0.13; // 衝突半径を少し縮小し、極細路の通り抜けやすさを最適化

            const isBlockedEdge = (nx, nz) => {
                if (nz < 0 || nz >= mapData.length || nx < 0 || nx >= mapData[0].length) return true;
                return mapData[nz][nx] === 0;
            };

            const leftEmpty = isBlockedEdge(gx - 1, gz);
            if (leftEmpty && (snek.x - snekRadius) < tileLeft) {
                return true;
            }

            const rightEmpty = isBlockedEdge(gx + 1, gz);
            if (rightEmpty && (snek.x + snekRadius) > tileRight) {
                return true;
            }

            const topEmpty = isBlockedEdge(gx, gz - 1);
            if (topEmpty && (snek.z - snekRadius) < tileTop) {
                return true;
            }

            const bottomEmpty = isBlockedEdge(gx, gz + 1);
            if (bottomEmpty && (snek.z + snekRadius) > tileBottom) {
                return true;
            }

            return false;
        }

        // 岩や高壁といった障害物への接近判定
        function checkObstacleCollision() {
            const gx = Math.floor(snek.x);
            const gz = Math.floor(snek.z);

            if (gz < 0 || gz >= mapData.length || gx < 0 || gx >= mapData[0].length) return false;

            const currentCell = mapData[gz][gx];
            if (currentCell === 3 || currentCell === 4) {
                return true;
            }

            const snekRadius = 0.13;

            if (gx > 0 && (mapData[gz][gx-1] === 3 || mapData[gz][gx-1] === 4)) {
                if ((snek.x - snekRadius) < gx) return true;
            }
            if (gx < mapData[0].length - 1 && (mapData[gz][gx+1] === 3 || mapData[gz][gx+1] === 4)) {
                if ((snek.x + snekRadius) > (gx + 1.0)) return true;
            }
            if (gz > 0 && (mapData[gz-1][gx] === 3 || mapData[gz-1][gx] === 4)) {
                if ((snek.z - snekRadius) < gz) return true;
            }
            if (gz < mapData.length - 1 && (mapData[gz+1][gx] === 3 || mapData[gz+1][gx] === 4)) {
                if ((snek.z + snekRadius) > (gz + 1.0)) return true;
            }

            return false;
        }

        // 衝突判定システム
        function checkCollisions() {
            if (spawnInvincibleTimer > 0) {
                spawnInvincibleTimer--;
                return;
            }

            if (checkRailingCollision()) {
                triggerCrash();
                return;
            }

            if (checkObstacleCollision()) {
                triggerCrash();
                return;
            }

            if (!checkOnPlatformWithGrace(snek.x, snek.z)) {
                gameState = STATE_FALLING;
                crashTimer = 0;
                return;
            }

            const ignoreCount = 8; 
            const maxCheckIndex = snek.bodySegments.length - ignoreCount;

            for (let i = 0; i < maxCheckIndex; i++) {
                const seg = snek.bodySegments[i];
                const dist = Math.hypot(snek.x - seg.position.x, snek.z - seg.position.z);
                if (dist < 0.35) {
                    triggerCrash();
                    return;
                }
            }

            const gridX = Math.floor(snek.x);
            const gridZ = Math.floor(snek.z);
            const cell = mapData[gridZ][gridX];
            if (cell === 2) {
                triggerClear();
            }
        }

        function triggerFall() {
            gameState = STATE_FALLING;
        }

        function triggerCrash() {
            if (gameState === STATE_CRASHED) return;
            gameState = STATE_CRASHED;
            crashTimer = 0;
            createCrashParticles(snek.x, snek.y, snek.z);
        }

