            gamePaused = false;
            
            document.getElementById("hud").style.opacity = "1";
            document.getElementById("restart-btn").style.opacity = "1";
            document.getElementById("pause-btn").style.opacity = "1";
            document.getElementById("instructions").style.opacity = "1";
            
            document.getElementById("pause-overlay").style.display = "none";
        });

        document.querySelectorAll('.home-action-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                document.getElementById("clear-overlay").style.display = "none";
                document.getElementById("fail-overlay").style.display = "none";
                document.getElementById("pause-overlay").style.display = "none";
                document.getElementById("select-overlay").style.display = "flex";
                buildStageSelectOverlay();
            });
        });

        document.querySelectorAll('.retry-action-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                loadLevel(currentLevelIndex);
            });
        });

        document.getElementById('next-btn').addEventListener('click', (e) => {
            e.stopPropagation();
            const nextIndex = (currentLevelIndex + 1) % STAGES.length;
            loadLevel(nextIndex);
        });

        document.getElementById('close-select-btn').addEventListener('click', (e) => {
            e.stopPropagation();
            document.getElementById("select-overlay").style.display = "none";
            
            if (gameState === STATE_CLEARED) {
                document.getElementById("clear-overlay").style.display = "flex";
            } else if (gamePaused) {
                document.getElementById("pause-overlay").style.display = "flex";
            } else {
                document.getElementById("fail-overlay").style.display = "flex";
            }
        });

        window.addEventListener('resize', () => {
            const aspect = window.innerWidth / window.innerHeight;
            camera.left = -d * aspect;
            camera.right = d * aspect;
            camera.top = d;
            camera.bottom = -d;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        // --- 開始 ---
        loadLevel(0);
        animate();

		</script>
</body>

</html>
