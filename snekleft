        // --- Snek 物理（旋回半径・速度比率を徹底最適化） ---
        let snek = {
            x: 0,
            z: 0,
            y: 0.5,
            angle: 0,
            speed: 0.040,       // 移動速度
            turnSpeed: 0.075,    // 旋回力を大幅強化（1マス幅通路でも絶対に曲がりきれる比率に改善）
            headGroup: null,
            bodySegments: [], 
            pathHistory: []
        };

        let lastSegmentPos = { x: 0, z: 0 };
        let isPressed = false;
        let crashTimer = 0;
        let particles = [];

        function resetSnek() {
            if (snek.headGroup) scene.remove(snek.headGroup);
            snek.bodySegments.forEach(seg => scene.remove(seg));
            snek.bodySegments = [];
