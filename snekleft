        function spawnBodySegment(pos) {
            const segGeo = new THREE.BoxGeometry(0.44, 0.44, 0.44);
            const segMesh = new THREE.Mesh(segGeo, materials.snekBody);
            segMesh.position.set(pos.x, snek.y, pos.z);
            segMesh.castShadow = true;
