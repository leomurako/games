        function clearLevel1Assist() {
            while (level1AssistGroup.children.length > 0) {
                const obj = level1AssistGroup.children[0];
                if (obj.isGroup) {
                    obj.children.forEach(child => {
                        if (child.geometry) child.geometry.dispose();
                        if (child.material) child.material.dispose();
                    });
                }
                level1AssistGroup.remove(obj);
            }
        }

		function updateLevel1Assist() {
			clearLevel1Assist();

			let tempX = snek.x;
			let tempZ = snek.z;
			let tempAngle = snek.angle;

			const deltaAngle = isPressed ? snek.turnSpeed : -snek.turnSpeed;
			const stepFrames = 4;
			const numPoints = 6;

			const initialOffsetFrames = 10; 
			for (let f = 0; f < initialOffsetFrames; f++) {
				tempAngle += deltaAngle;
				tempX += Math.cos(tempAngle) * snek.speed;
				tempZ += -Math.sin(tempAngle) * snek.speed;
			}

			const legGeo = new THREE.BoxGeometry(0.18, 0.02, 0.04);
			const indicatorMat = new THREE.MeshBasicMaterial({ color: 0xFFFFFF, transparent: true, opacity: 0.85 });

			for (let i = 1; i <= numPoints; i++) {
				for (let f = 0; f < stepFrames; f++) {
					tempAngle += deltaAngle;
					tempX += Math.cos(tempAngle) * snek.speed;
					tempZ += -Math.sin(tempAngle) * snek.speed;
				}

				const group = new THREE.Group();
				group.position.set(tempX, 0.015, tempZ);
				group.rotation.y = tempAngle + Math.PI;

				const topLeg = new THREE.Mesh(legGeo, indicatorMat);
				topLeg.position.set(0, 0, -0.05);
				topLeg.rotation.y = Math.PI / 4;

				const botLeg = new THREE.Mesh(legGeo, indicatorMat);
				botLeg.position.set(0, 0, 0.05);
				botLeg.rotation.y = -Math.PI / 4;

				group.add(topLeg, botLeg);
				level1AssistGroup.add(group);
			}
		}

