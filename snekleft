<!DOCTYPE html>
<html lang="ja">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
	<title>Snek Left 3D - Ultimate Grand Edition</title>
	<style>
		body {
			margin: 0;
			padding: 0;
			overflow: hidden;
			background-color: #0099FF;
			font-family: 'Helvetica Neue', Arial, sans-serif;
			user-select: none;
		}

		#game-container {
			width: 100vw;
			height: 100vh;
			display: block;
		}

		/* HUD */
		#hud {
			position: absolute;
			top: 20px;
			left: 50%;
			transform: translateX(-50%);
			color: #ffffff;
			font-size: 24px;
			font-weight: bold;
			text-shadow: 2px 2px 0px rgba(0, 0, 0, 0.3);
			pointer-events: none;
			text-align: center;
			z-index: 10;
		}

		#level-name {
			font-size: 13px;
			font-weight: normal;
			opacity: 0.95;
			margin-top: 4px;
			letter-spacing: 0.5px;
		}

		#instructions {
			position: absolute;
			bottom: 40px;
			left: 50%;
			transform: translateX(-50%);
			color: #ffffff;
			font-size: 14px;
			text-shadow: 1px 1px 0px rgba(0, 0, 0, 0.4);
			pointer-events: none;
			text-align: center;
			background-color: rgba(0, 0, 0, 0.35);
			padding: 10px 20px;
			border-radius: 20px;
			line-height: 1.5;
			z-index: 10;
		}

		/* 3Dボタンデザイン */
		.fancade-btn {
			border: none;
			border-radius: 50%;
			display: flex;
			justify-content: center;
			align-items: center;
			cursor: pointer;
			font-size: 38px;
			color: white;
			transition: transform 0.1s, box-shadow 0.1s;
			outline: none;
		}

		.btn-home {
			background-color: #5D9CEC;
			box-shadow: 0 9px 0 #4A89DC;
			width: 90px;
			height: 90px;
		}

		.btn-home:active {
			transform: translateY(5px);
			box-shadow: 0 4px 0 #4A89DC;
		}

		.btn-retry {
			background-color: #FFCE54;
			box-shadow: 0 9px 0 #F6BB42;
			width: 90px;
			height: 90px;
		}

		.btn-retry:active {
			transform: translateY(5px);
			box-shadow: 0 4px 0 #F6BB42;
		}

		.btn-next {
			background-color: #A0D468;
			box-shadow: 0 11px 0 #8CC152;
			width: 115px;
			height: 115px;
			font-size: 52px;
			border-radius: 50%;
		}

		.btn-next:active {
			transform: translateY(6px);
			box-shadow: 0 5px 0 #8CC152;
		}

		#restart-btn {
			position: absolute;
			top: 20px;
			right: 20px;
			width: 44px;
			height: 44px;
			font-size: 18px;
			border-radius: 50%;
			z-index: 20;
		}

		#pause-btn {
			position: absolute;
			top: 20px;
			left: 20px;
			width: 44px;
			height: 44px;
			font-size: 18px;
			border-radius: 50%;
			z-index: 20;
		}

		/* ぼかし背景オーバーレイ */
		.overlay {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background-color: rgba(0, 0, 0, 0.45);
			backdrop-filter: blur(8px);
			-webkit-backdrop-filter: blur(8px);
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			color: #fff;
			display: none;
			z-index: 100;
		}

		/* 斜めのポラロイド写真カード */
		.photo-card {
			background-color: #ffffff;
			border-radius: 18px;
			padding: 16px;
			box-shadow: 0 15px 45px rgba(0, 0, 0, 0.5);
			transform: rotate(-3deg);
			width: 380px;
			display: flex;
			flex-direction: column;
			align-items: center;
			border: 12px solid #ffffff;
			margin-bottom: 35px;
			animation: popCard 0.45s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		}

		@keyframes popCard {
			0% {
				transform: scale(0.5) rotate(15deg);
				opacity: 0;
			}

			100% {
				transform: scale(1) rotate(-3deg);
				opacity: 1;
			}
		}

		.photo-card img {
			width: 100%;
			border-radius: 10px;
			aspect-ratio: 4/3;
			object-fit: cover;
			box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.15);
			background-color: #eee;
		}

		.photo-card h2 {
			color: #333333;
			font-size: 24px;
			margin: 18px 0 2px 0;
			font-weight: 900;
			letter-spacing: 1px;
		}

		.button-row {
			display: flex;
			gap: 20px;
			justify-content: center;
			align-items: center;
		}

		/* 25ステージ対応スクロールグリッド */
		#stage-grid {
			display: grid;
			grid-template-columns: repeat(5, 1fr);
			gap: 12px;
			max-width: 380px;
			max-height: 320px;
			overflow-y: auto;
			margin-bottom: 30px;
			padding: 10px;
			background-color: rgba(255, 255, 255, 0.1);
			border-radius: 12px;
		}
	</style>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>

<body>

	<div id="game-container"></div>

	<!-- 通常HUD -->
	<div id="hud">
		<div id="level-num">LEVEL 1</div>
		<div id="level-name">Straight Forward</div>
	</div>

	<div id="instructions">
		タップ / スペースキー長押し：【左旋回】<br>
        離す：【右旋回】（スタートと同時に自動的に右に回り始めます）
    </div>

		<!-- クイック再起動 ＆ ポーズ -->
		<button id="restart-btn" class="fancade-btn btn-retry" style="font-size: 18px; width: 44px; height: 44px; box-shadow: 0 4px 0 #F6BB42;">↻</button>
		<button id="pause-btn" class="fancade-btn btn-home" style="font-size: 18px; width: 44px; height: 44px; box-shadow: 0 4px 0 #4A89DC;">⏸</button>

		<!-- ステージクリア演出 -->
		<div id="clear-overlay" class="overlay">
			<div class="photo-card">
				<img id="win-photo" src="" alt="Clear Snapshot">
				<h2>STAGE CLEARED!</h2>
			</div>
			<div class="button-row">
				<button class="fancade-btn btn-home home-action-btn">🏠</button>
				<button class="fancade-btn btn-retry retry-action-btn">↻</button>
				<button id="next-btn" class="fancade-btn btn-next">▶</button>
			</div>
		</div>

		<!-- ゲームオーバー演出 -->
		<div id="fail-overlay" class="overlay">
			<div class="photo-card" style="transform: rotate(3deg);">
				<img id="fail-photo" src="" alt="Fail Snapshot">
				<h2 style="color: #D24B4C;">GAME OVER!</h2>
			</div>
			<div class="button-row">
				<button class="fancade-btn btn-home home-action-btn">🏠</button>
				<button class="fancade-btn btn-retry retry-action-btn">↻</button>
			</div>
		</div>

		<!-- 一時停止演出 -->
		<div id="pause-overlay" class="overlay">
			<div class="photo-card" style="transform: rotate(-1deg);">
				<img id="pause-photo" src="" alt="Pause Snapshot">
				<h2>GAME PAUSED</h2>
			</div>
			<div class="button-row">
				<button class="fancade-btn btn-home home-action-btn">🏠</button>
				<button class="fancade-btn btn-retry retry-action-btn">↻</button>
				<button id="resume-btn" class="fancade-btn btn-next">▶</button>
			</div>
		</div>

		<!-- ステージ選択画面オーバーレイ -->
		<div id="select-overlay" class="overlay">
			<h1 style="font-size: 28px; font-weight: 900; margin-bottom: 24px; letter-spacing: 1px;">SELECT STAGE</h1>
			<div id="stage-grid"></div>
			<button id="close-select-btn" class="fancade-btn btn-retry" style="border-radius: 8px; width: auto; height: auto; padding: 10px 24px; font-size: 15px; box-shadow: 0 5px 0 #F6BB42;">CLOSE</button>
		</div>

		<script>
			// --- ゲーム状態 ---
        const STATE_PLAYING = 1;
        const STATE_CRASHED = 2;
        const STATE_FALLING = 3;
        const STATE_CLEARED = 4;
        let gameState = STATE_PLAYING;
        let gamePaused = false;
        let spawnInvincibleTimer = 0;

        // --- 本家イメージカラー完全固定 ---
        const colors = {
            background: 0x0099FF,  // 空
            grass: 0x42C151,       // 芝生
            dirt: 0xF7A189,        // 土側面
            fencePost: 0xD24B4C,   // 支柱（赤）
            fenceRail: 0xFA8C8C,   // 横棒（ピンク）
            archStone: 0x9AA5B0,   // アーチ石・高壁（グレー）
            archSnow: 0xFFFFFF,    // 雪
            spectator: 0xFB7A9F,   // 観客（ピンク）
            snekYellow: 0xFCD711,  // 蛇
            snekEyeWhite: 0xffffff,
            snekEyePupil: 0x000000
        };

        // --- 本家準拠の「全25ステージ」手書き完全再構築データ ---
        const STAGES = [
            // 1: Straight Forward (まっすぐ進む)
            { name: "Straight Forward", startX: 12.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0000000000000000","0000111111111100","0022111111111100","0022111111111100","0000111111111100","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 2: Turn Around (Uターン)
            { name: "Turn Around", startX: 10.5, startZ: 3.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0001111111111000","0001111111111000","0001100000011000","0001100220011000","0001111221111000","0001111111111000","0000000000000000","0000000000000000"
            ]},
            // 3: Go West (まっすぐ進んで左へ曲がる)
            { name: "Go West", startX: 11.5, startZ: 3.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0000111111111000","0000111111111000","0000110000000000","0000110000000000","0000220000000000","0000220000000000","0000000000000000","0000000000000000"
            ]},
            // 4: Easy Right (右側を回って下に進む)
            { name: "Easy Right", startX: 4.5, startZ: 3.5, startAngle: 0, map: [
                "0000000000000000","0000000000000000","0000111111111000","0000111111111000","0000000000011000","0000000000011000","0000000000022000","0000000000022000","0000000000000000","0000000000000000"
            ]},
            // 5: Looong (大きく反時計回りに大回り)
            { name: "Looong", startX: 11.5, startZ: 6.5, startAngle: -Math.PI/2, map: [
                "0000000000000000","0000111111111100","0000111111111100","0000110000001100","0000110000001100","0000220000001100","0000221111111100","0000111111111100","0000000000000000","0000000000000000"
            ]},
            // 6: Obstruction (途中の低い障害物を避ける)
            { name: "Obstruction", startX: 11.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0001111111111000","0001111331111000","0022111111111000","0022111111111000","0001111331111000","0001111111111000","0000000000000000","0000000000000000"
            ]},
            // 7: The Cube (巨大な正方形の壁)
            { name: "The Cube", startX: 11.5, startZ: 2.5, startAngle: Math.PI, map: [
                "0000000000000000","0001111111111000","0001111111111000","0001144444111000","0001144444111000","0001111111111000","0001111111111000","0001111221111000","0000000220000000","0000000000000000"
            ]},
            // 8: Open Goal (左半分全体がゴール)
            { name: "Open Goal", startX: 11.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0000222211111000","0000222211111000","0000222211111000","0000222211111000","0000222211111000","0000222211111000","0000222211111000","0000000000000000","0000000000000000"
            ]},
            // 9: Portal Back (アーチ門を折り返す)
            { name: "Portal Back", startX: 7.5, startZ: 2.5, startAngle: Math.PI/2, map: [
                "0000000000000000","0000001111000000","0000001111000000","0000001111000000","0000001111000000","0000001111000000","0000002222000000","0000002222000000","0000000000000000","0000000000000000"
            ]},
            // 10: Thin Line (極細の一本道)
            { name: "Thin Line", startX: 12.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0000000000000000","0000111111111100","0022111111111100","0022111111111100","0000111111111100","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 11: U Win (U字を回る)
            { name: "U Win", startX: 4.5, startZ: 6.5, startAngle: -Math.PI/2, map: [
                "0000000000000000","0001111111111000","0001111111111000","0001100000011000","0001100000011000","0001100000022000","0001100000022000","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 12: Petrified (多くの障害物)
            { name: "Petrified", startX: 11.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0001111111111000","0001131113111000","0001111111111000","0022111311111000","0022111111131000","0001111111111000","0001111111111000","0000000000000000","0000000000000000"
            ]},
            // 13: Race Track (一周周回コース)
            { name: "Race Track", startX: 4.5, startZ: 6.5, startAngle: -Math.PI/2, map: [
                "0000000000000000","0001111111111000","0001111111111000","0001100000011000","0001100000011000","0001100022011000","0001111122111000","0001111111111000","0000000000000000","0000000000000000"
            ]},
            // 14: Step Down (仕切りを下りるジグザグ)
            { name: "Step Down", startX: 3.5, startZ: 2.5, startAngle: 0, map: [
                "0000000000000000","0001111110000000","0001111110000000","0000000110000000","0000000111111000","0000000111111000","0000000000022000","0000000000022000","0000000000000000","0000000000000000"
            ]},
            // 15: Stairway (ジグザグ高壁)
            { name: "Stairway", startX: 11.5, startZ: 6.5, startAngle: -Math.PI/2, map: [
                "0000000000022000","0001111111122000","0001144444111000","0001144444111000","0001111144111000","0001111144111000","0001111111111000","0001111111111000","0000000000000000","0000000000000000"
            ]},
            // 16: Base Jump (離れた足場に大ジャンプ)
            { name: "Base Jump", startX: 11.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0001111000111100","0001111000111100","0002222000111100","0002222000111100","0001111000111100","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 17: Edge Case (端のきわどい岩)
            { name: "Edge Case", startX: 11.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0001111111111000","0001111311111000","0022111111111000","0022111111111000","0001111111111000","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 18: Venice (水路を避ける大回り)
            { name: "Venice", startX: 11.5, startZ: 6.5, startAngle: -Math.PI/2, map: [
                "0000000000000000","0001111111111000","0001111111111000","0001100000011000","0001100000011000","0002200000011000","0002200000011000","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 19: Too Close (超至近距離ゴール)
            { name: "Too Close", startX: 8.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0000001111000000","0000001111000000","0000022111000000","0000022111000000","0000001111000000","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 20: Upside Down (下部を回る逆向きU)
            { name: "Upside Down", startX: 4.5, startZ: 2.5, startAngle: Math.PI/2, map: [
                "0000000000000000","0001111111111000","0001111111111000","0001100000011000","0001100000011000","0002200000011000","0002200000011000","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 21: Knot (狭い結び目での衝突回避)
            { name: "Knot", startX: 11.5, startZ: 6.5, startAngle: -Math.PI/2, map: [
                "0000000000000000","0001111111111000","0001100000011000","0001100111111000","0001100111111000","0002200110011000","0002200110011000","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 22: Tunnel Vision (高壁の狭いトンネル)
            { name: "Tunnel Vision", startX: 11.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0004444444444000","0004444444444000","0022111111111000","0022111111111000","0004444444444000","0004444444444000","0000000000000000","0000000000000000"
            ]},
            // 23: Hard Left (タイトな左急旋回)
            { name: "Hard Left", startX: 11.5, startZ: 6.5, startAngle: -Math.PI/2, map: [
                "0000000000000000","0001111111111000","0001111111111000","0001100000000000","0001100000000000","0002200000000000","0002200000000000","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 24: Overpass (GG! の高壁)
            { name: "Overpass", startX: 4.5, startZ: 6.5, startAngle: -Math.PI/2, map: [
                "0000000000000000","0001111111111000","0001111111111000","0001144444011000","0001144444011000","0002200000011000","0002200000011000","0000000000000000","0000000000000000","0000000000000000"
            ]},
            // 25: Thank You (感謝のラストラン)
            { name: "Thank You", startX: 11.5, startZ: 4.5, startAngle: Math.PI, map: [
                "0000000000000000","0000000000000000","0001111111111000","0001111111111000","0022110000000000","0022110000000000","0001111111111000","0001111111111000","0000000000000000","0000000000000000"
            ]}
        ];

        // RLEから二次元配列に変換するユーティリティ
        function parseMapData(stringArray) {
            return stringArray.map(line => line.split('').map(char => parseInt(char)));
        }

        let currentLevelIndex = 0;
        let activeStage = STAGES[currentLevelIndex];
        let mapData = parseMapData(activeStage.map);

        // --- Three.js 基本セットアップ ---
        const container = document.getElementById('game-container');
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(colors.background);

        const aspect = window.innerWidth / window.innerHeight;
        const d = 5.5; 
        const camera = new THREE.OrthographicCamera(-d * aspect, d * aspect, d, -d, 1, 1000);
        camera.position.set(12, 10, 12);

        const renderer = new THREE.WebGLRenderer({ antialias: true, preserveDrawingBuffer: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        container.appendChild(renderer.domElement);

        // --- ライティング ---
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.75);
        scene.add(ambientLight);

        const dirLight = new THREE.DirectionalLight(0xffffff, 0.85);
        dirLight.position.set(15, 25, 10);
        dirLight.castShadow = true;
        dirLight.shadow.mapSize.width = 1024;
        dirLight.shadow.mapSize.height = 1024;
        dirLight.shadow.camera.left = -10;
        dirLight.shadow.camera.right = 10;
        dirLight.shadow.camera.top = 10;
        dirLight.shadow.camera.bottom = -10;
        dirLight.shadow.camera.near = 0.5;
        dirLight.shadow.camera.far = 45;
        scene.add(dirLight);

        // --- 固定マテリアル ---
        const materials = {
            grass: new THREE.MeshLambertMaterial({ color: colors.grass }),
            dirt: new THREE.MeshLambertMaterial({ color: colors.dirt }),
            fencePost: new THREE.MeshLambertMaterial({ color: colors.fencePost }),
            fenceRail: new THREE.MeshLambertMaterial({ color: colors.fenceRail }),
            archStone: new THREE.MeshLambertMaterial({ color: colors.archStone }),
            archSnow: new THREE.MeshLambertMaterial({ color: colors.archSnow }),
            spectator: new THREE.MeshLambertMaterial({ color: colors.spectator }),
            snekHead: new THREE.MeshStandardMaterial({ color: colors.snekYellow, roughness: 0.3 }),
            snekBody: new THREE.MeshStandardMaterial({ color: colors.snekYellow, roughness: 0.4 }),
            eyeWhite: new THREE.MeshBasicMaterial({ color: colors.snekEyeWhite }),
            eyePupil: new THREE.MeshBasicMaterial({ color: colors.snekEyePupil }),
            whiteGoal: new THREE.MeshLambertMaterial({ color: 0xffffff }),
            blackGoal: new THREE.MeshLambertMaterial({ color: 0x111111 })
        };

        let mapGroup = new THREE.Group();
        scene.add(mapGroup);

        let spectatorMeshes = [];
        let level1AssistGroup = new THREE.Group();
        scene.add(level1AssistGroup);

        // --- 3Dマップの構築 ---
        function buildMap() {
            while(mapGroup.children.length > 0){
                mapGroup.remove(mapGroup.children[0]);
            }
            spectatorMeshes = [];

            activeStage = STAGES[currentLevelIndex];
            mapData = parseMapData(activeStage.map);

            // HUD表示更新
            document.getElementById('level-num').innerText = `LEVEL ${currentLevelIndex + 1}`;
            document.getElementById('level-name').innerText = activeStage.name;

            const boxGeo = new THREE.BoxGeometry(1, 1, 1);
            const obsGeo = new THREE.BoxGeometry(0.8, 0.8, 0.8);
            const wallGeo = new THREE.BoxGeometry(0.96, 2.5, 0.96);

            for (let z = 0; z < mapData.length; z++) {
                for (let x = 0; x < mapData[z].length; x++) {
                    const cell = mapData[z][x];
                    
                    if (cell === 1 || cell === 3 || cell === 4) {
                        const grassMesh = new THREE.Mesh(boxGeo, materials.grass);
                        grassMesh.position.set(x + 0.5, -0.5, z + 0.5);
                        grassMesh.receiveShadow = true;
                        grassMesh.castShadow = true;
                        mapGroup.add(grassMesh);

                        const dirtMesh = new THREE.Mesh(boxGeo, materials.dirt);
                        dirtMesh.position.set(x + 0.5, -1.5, z + 0.5);
                        dirtMesh.receiveShadow = true;
                        dirtMesh.castShadow = true;
                        mapGroup.add(dirtMesh);

                        // 隣接判定を強化し、ゴール前などの理不尽な手すり生成を完全に回避
                        generateRailingsForTile(x, z);

                        if (cell === 3) {
                            const obsMesh = new THREE.Mesh(obsGeo, materials.archStone);
                            obsMesh.position.set(x + 0.5, 0.4, z + 0.5);
                            obsMesh.castShadow = true;
                            obsMesh.receiveShadow = true;
                            mapGroup.add(obsMesh);
                        } else if (cell === 4) {
                            const wallMesh = new THREE.Mesh(wallGeo, materials.archStone);
                            wallMesh.position.set(x + 0.5, 1.25, z + 0.5);
                            wallMesh.castShadow = true;
                            wallMesh.receiveShadow = true;
                            mapGroup.add(wallMesh);

                            const snowMesh = new THREE.Mesh(new THREE.BoxGeometry(1.0, 0.1, 1.0), materials.archSnow);
                            snowMesh.position.set(x + 0.5, 2.55, z + 0.5);
                            snowMesh.castShadow = true;
                            mapGroup.add(snowMesh);
                        }
                    } else if (cell === 2) {
                        const dirtMesh = new THREE.Mesh(boxGeo, materials.dirt);
                        dirtMesh.position.set(x + 0.5, -1.5, z + 0.5);
                        dirtMesh.receiveShadow = true;
                        dirtMesh.castShadow = true;
                        mapGroup.add(dirtMesh);

                        const goalGroup = new THREE.Group();
                        goalGroup.position.set(x + 0.5, -0.5, z + 0.5);
                        
                        const subSize = 0.5;
                        const subGeo = new THREE.BoxGeometry(subSize, 1, subSize);
                        const subTiles = [
                            {x: -0.25, z: -0.25, mat: (x + z) % 2 === 0 ? materials.whiteGoal : materials.blackGoal},
                            {x: 0.25, z: -0.25, mat: (x + z) % 2 === 1 ? materials.whiteGoal : materials.blackGoal},
                            {x: -0.25, z: 0.25, mat: (x + z) % 2 === 1 ? materials.whiteGoal : materials.blackGoal},
                            {x: 0.25, z: 0.25, mat: (x + z) % 2 === 0 ? materials.whiteGoal : materials.blackGoal}
                        ];

                        subTiles.forEach(tile => {
                            const mesh = new THREE.Mesh(subGeo, tile.mat);
                            mesh.position.set(tile.x, 0, tile.z);
                            mesh.receiveShadow = true;
                            mesh.castShadow = true;
                            goalGroup.add(mesh);
                        });
